      "version": 1
    },
    {
      "id": "fast_head",
      "type": "text",
      "x": 320,
      "y": 55,
      "strokeColor": "#2f9e44",
      "text": "LOOKUP TABLE APPROACH (fast — the correct method)",
      "fontSize": 16,
      "createdAt": "2026-04-02T20:41:49.039Z",
      "updatedAt": "2026-04-02T20:41:49.039Z",
      "version": 1
    },
    {
      "id": "precomp_box",
      "type": "rectangle",
      "x": 320,
      "y": 80,
      "width": 310,
      "height": 70,
      "backgroundColor": "#b2f2bb",
      "strokeColor": "#2f9e44",
      "strokeWidth": 2,
      "createdAt": "2026-04-02T20:41:49.039Z",
      "updatedAt": "2026-04-02T20:41:49.039Z",
      "version": 1
    },
    {
      "id": "mnhxxa7hxel2gghsdk",
      "type": "text",
      "x": 330,
      "y": 88,
      "strokeColor": "#2f9e44",
      "text": "Step A: Precompute distance table T (once per query)",
      "fontSize": 13,
      "createdAt": "2026-04-02T20:41:49.039Z",
      "updatedAt": "2026-04-02T20:41:49.039Z",
      "version": 1
    },
    {
      "id": "mnhxxa7hv8oshh54g1s",
      "type": "text",
      "x": 330,
      "y": 105,
      "strokeColor": "#555555",
      "text": "For each subspace m, for each centroid k:",
      "fontSize": 11,
      "createdAt": "2026-04-02T20:41:49.039Z",
      "updatedAt": "2026-04-02T20:41:49.039Z",
      "version": 1
    },
    {
      "id": "mnhxxa7hwylwvb6uhvl",
      "type": "text",
      "x": 330,
      "y": 120,
      "strokeColor": "#555555",
      "text": "  T[m][k] = ||q_m - centroid_m_k||^2",
      "fontSize": 11,
      "fontFamily": 3,
      "createdAt": "2026-04-02T20:41:49.039Z",
      "updatedAt": "2026-04-02T20:41:49.039Z",
      "version": 1
    },
    {
      "id": "mnhxxa7h1ftfzq8rnlp",
      "type": "text",
      "x": 330,
      "y": 137,
      "strokeColor": "#0c8599",
      "text": "Table: 8 subspaces × 256 entries = 2,048 floats = 8 KB",
      "fontSize": 11,
      "createdAt": "2026-04-02T20:41:49.039Z",
      "updatedAt": "2026-04-02T20:41:49.039Z",
      "version": 1
    },
    {
      "id": "mnhxxa7hso9w50vhet",
      "type": "text",
      "x": 630,
      "y": 100,
      "strokeColor": "#0c8599",
      "text": "Fits in\nL1 cache!",
      "fontSize": 12,
      "createdAt": "2026-04-02T20:41:49.039Z",
      "updatedAt": "2026-04-02T20:41:49.039Z",
      "version": 1
    },
    {
