    {
      "id": "mnhxxa7hlcu0xi3p6zo",
      "type": "text",
      "x": 330,
      "y": 293,
      "strokeColor": "#2f9e44",
      "text": "Step B: For each candidate (code=[47,193,88,...])",
      "fontSize": 13,
      "createdAt": "2026-04-02T20:41:49.039Z",
      "updatedAt": "2026-04-02T20:41:49.039Z",
      "version": 1
    },
    {
      "id": "mnhxxa7hzbzdkk3cylk",
      "type": "text",
      "x": 330,
      "y": 310,
      "strokeColor": "#2f9e44",
      "text": "dist = T[0][47] + T[1][193] + T[2][88] + ...",
      "fontSize": 11,
      "fontFamily": 3,
      "createdAt": "2026-04-02T20:41:49.039Z",
      "updatedAt": "2026-04-02T20:41:49.039Z",
      "version": 1
    },
    {
      "id": "mnhxxa7hurtloeaxeto",
      "type": "text",
      "x": 330,
      "y": 325,
      "strokeColor": "#555555",
      "text": "     = 0.42   + 0.29   + 2.91   + ... = 9.87",
      "fontSize": 11,
      "fontFamily": 3,
      "createdAt": "2026-04-02T20:41:49.039Z",
      "updatedAt": "2026-04-02T20:41:49.039Z",
      "version": 1
    },
    {
      "id": "mnhxxa7htv0ul1kv4vj",
      "type": "text",
      "x": 330,
      "y": 342,
      "strokeColor": "#2f9e44",
      "text": "Just 8 array lookups + 7 additions!",
      "fontSize": 13,
      "createdAt": "2026-04-02T20:41:49.039Z",
      "updatedAt": "2026-04-02T20:41:49.039Z",
      "version": 1
    },
    {
      "id": "mnhxxa7hndnflhmcdqm",
      "type": "text",
      "x": 330,
      "y": 360,
      "strokeColor": "#0c8599",
      "text": "↑ these are cache hits (table in L1 cache)",
      "fontSize": 11,
      "createdAt": "2026-04-02T20:41:49.039Z",
      "updatedAt": "2026-04-02T20:41:49.039Z",
      "version": 1
    },
    {
      "id": "mnhxxa7h10sd2cya3t8c",
      "type": "text",
      "x": 320,
      "y": 390,
      "strokeColor": "#2f9e44",
      "text": "Cost per candidate: O(M) = 8 ops",
      "fontSize": 13,
      "createdAt": "2026-04-02T20:41:49.039Z",
      "updatedAt": "2026-04-02T20:41:49.039Z",
      "version": 1
    },
    {
      "id": "mnhxxa7haqsk679kjr",
      "type": "text",
      "x": 320,
      "y": 408,
      "strokeColor": "#888888",
      "text": "16x fewer operations than exact (128D vs 8D).",
      "fontSize": 12,
      "createdAt": "2026-04-02T20:41:49.039Z",
      "updatedAt": "2026-04-02T20:41:49.039Z",
      "version": 1
    },
    {
      "id": "mnhxxa7hqcsinwslape",
      "type": "text",
      "x": 320,
      "y": 425,
      "strokeColor": "#888888",
      "text": "Plus: table precomputed once, amortized over thousands of candidates.",
      "fontSize": 12,
      "createdAt": "2026-04-02T20:41:49.039Z",
      "updatedAt": "2026-04-02T20:41:49.039Z",
      "version": 1
    },
