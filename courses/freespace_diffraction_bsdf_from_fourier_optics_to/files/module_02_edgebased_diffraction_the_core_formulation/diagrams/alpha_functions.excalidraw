    {
      "id": "mnjro401tg88cd9oq3d",
      "type": "text",
      "x": 45,
      "y": 265,
      "strokeColor": "#1e1e1e",
      "text": "Limits:",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-04T03:22:15.750Z",
      "updatedAt": "2026-04-04T03:22:15.750Z",
      "version": 1
    },
    {
      "id": "mnjro401rxcxklig0r",
      "type": "text",
      "x": 45,
      "y": 285,
      "strokeColor": "#9c36b5",
      "text": "ζ_x → 0:  α₁ → −ζ_x ζ_y / (16π ζ²)  → 0",
      "fontSize": 12,
      "fontFamily": 3,
      "createdAt": "2026-04-04T03:22:15.750Z",
      "updatedAt": "2026-04-04T03:22:15.750Z",
      "version": 1
    },
    {
      "id": "mnjro401dj24ub87td",
      "type": "text",
      "x": 45,
      "y": 305,
      "strokeColor": "#9c36b5",
      "text": "ζ → 0:    α₁ → 0  (finite everywhere)",
      "fontSize": 12,
      "fontFamily": 3,
      "createdAt": "2026-04-04T03:22:15.750Z",
      "updatedAt": "2026-04-04T03:22:15.750Z",
      "version": 1
    },
    {
      "id": "mnjro401r9h44q70g08",
      "type": "text",
      "x": 45,
      "y": 330,
      "strokeColor": "#f08c00",
      "text": "Taylor: cos(u)−sinc(u) ≈ −u²/8 + u⁴/192 ...",
      "fontSize": 12,
      "fontFamily": 3,
      "createdAt": "2026-04-04T03:22:15.750Z",
      "updatedAt": "2026-04-04T03:22:15.750Z",
      "version": 1
    },
    {
      "id": "mnjro401ydos1458qae",
      "type": "text",
      "x": 45,
      "y": 350,
      "strokeColor": "#f08c00",
      "text": "Use Taylor when |ζ_x| < 1e-4  for stability",
      "fontSize": 12,
      "createdAt": "2026-04-04T03:22:15.750Z",
      "updatedAt": "2026-04-04T03:22:15.750Z",
      "version": 1
    },
    {
      "id": "mnjro401h9hxq1vbpnc",
      "type": "text",
      "x": 45,
      "y": 385,
      "strokeColor": "#e03131",
      "text": "GOTCHA: np.sinc(x) = sin(πx)/(πx)  ← WRONG!",
      "fontSize": 13,
      "fontFamily": 3,
      "createdAt": "2026-04-04T03:22:15.750Z",
      "updatedAt": "2026-04-04T03:22:15.750Z",
      "version": 1
    },
    {
      "id": "mnjro4017tlmro7rcck",
      "type": "text",
      "x": 45,
      "y": 405,
      "strokeColor": "#2f9e44",
      "text": "Use:  np.where(|u|<1e-12, 1, np.sin(u)/u)",
      "fontSize": 13,
      "fontFamily": 3,
      "createdAt": "2026-04-04T03:22:15.750Z",
      "updatedAt": "2026-04-04T03:22:15.750Z",
      "version": 1
    },
    {
      "id": "mnjro401h2kgdeuqbcq",
      "type": "text",
      "x": 45,
      "y": 435,
      "strokeColor": "#1971c2",
      "text": "Opposing edges: α₁(−ζ) = −α₁(ζ)  → edges cancel  ✓",
      "fontSize": 13,
      "createdAt": "2026-04-04T03:22:15.750Z",
      "updatedAt": "2026-04-04T03:22:15.750Z",
      "version": 1
    },
