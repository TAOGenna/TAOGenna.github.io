    },
    {
      "id": "mnjro401jmt00r9b0t",
      "type": "text",
      "x": 555,
      "y": 285,
      "strokeColor": "#9c36b5",
      "text": "ζ_x → 0:  α₂ → ζ_y / (2π ζ_y²) = 1/(2πζ_y)",
      "fontSize": 12,
      "fontFamily": 3,
      "createdAt": "2026-04-04T03:22:15.751Z",
      "updatedAt": "2026-04-04T03:22:15.751Z",
      "version": 1
    },
    {
      "id": "mnjro401nnpiqrxdxn",
      "type": "text",
      "x": 555,
      "y": 305,
      "strokeColor": "#e03131",
      "text": "ζ → 0:    α₂ → ∞  (diverges — but ψⱼ stays finite)",
      "fontSize": 12,
      "fontFamily": 3,
      "createdAt": "2026-04-04T03:22:15.751Z",
      "updatedAt": "2026-04-04T03:22:15.751Z",
      "version": 1
    },
    {
      "id": "mnjro401w4eaal93xgd",
      "type": "text",
      "x": 555,
      "y": 330,
      "strokeColor": "#f08c00",
      "text": "sinc(ζ_x/2) → 1 as ζ_x → 0",
      "fontSize": 12,
      "fontFamily": 3,
      "createdAt": "2026-04-04T03:22:15.751Z",
      "updatedAt": "2026-04-04T03:22:15.751Z",
      "version": 1
    },
    {
      "id": "mnjro401qutw16ki37d",
      "type": "text",
      "x": 555,
      "y": 350,
      "strokeColor": "#f08c00",
      "text": "Only ζ_y = 0 line is singular (m̂ ⊥ ξ direction)",
      "fontSize": 12,
      "createdAt": "2026-04-04T03:22:15.751Z",
      "updatedAt": "2026-04-04T03:22:15.751Z",
      "version": 1
    },
    {
      "id": "mnjro401h2qbebo5m",
      "type": "text",
      "x": 555,
      "y": 380,
      "strokeColor": "#1971c2",
      "text": "Power: ℑ₂ = ∫|α₂|² dζ  = 0.11487543",
      "fontSize": 13,
      "fontFamily": 3,
      "createdAt": "2026-04-04T03:22:15.751Z",
      "updatedAt": "2026-04-04T03:22:15.751Z",
      "version": 1
    },
    {
      "id": "mnjro401ww7ou24hhtd",
      "type": "text",
      "x": 555,
      "y": 400,
      "strokeColor": "#e03131",
      "text": "Power: ℑ₁ = ∫|α₁|² dζ  = 0.0045255085",
      "fontSize": 13,
      "fontFamily": 3,
      "createdAt": "2026-04-04T03:22:15.751Z",
      "updatedAt": "2026-04-04T03:22:15.751Z",
      "version": 1
    },
    {
      "id": "mnjro401gpqqrixj9lo",
      "type": "text",
      "x": 555,
      "y": 420,
      "strokeColor": "#9c36b5",
      "text": "Ratio ℑ₂/ℑ₁ ≈ 25.4:  α₂ carries 25× more power!",
      "fontSize": 13,
      "createdAt": "2026-04-04T03:22:15.751Z",
      "updatedAt": "2026-04-04T03:22:15.751Z",
      "version": 1
