      "x": 45,
      "y": 62,
      "strokeColor": "#e03131",
      "text": "α₁(ζ) — odd in both ζ_x and ζ_y",
      "fontSize": 16,
      "fontFamily": 2,
      "createdAt": "2026-04-04T03:22:15.750Z",
      "updatedAt": "2026-04-04T03:22:15.750Z",
      "version": 1
    },
    {
      "id": "mnjro4018v17l417wg5",
      "type": "text",
      "x": 45,
      "y": 88,
      "strokeColor": "#e03131",
      "text": "α₁(ζ) = ζ_y / (2π ζ² ζ_x) · (cos(ζ_x/2) − sin(ζ_x/2)/(ζ_x/2))",
      "fontSize": 13,
      "fontFamily": 3,
      "createdAt": "2026-04-04T03:22:15.750Z",
      "updatedAt": "2026-04-04T03:22:15.750Z",
      "version": 1
    },
