      "version": 1
    },
    {
      "id": "mnjrn7k6ewgysr1bxlg",
      "type": "text",
      "x": 55,
      "y": 320,
      "strokeColor": "#2f9e44",
      "text": "aⱼ = φ(vⱼ - eⱼ/2)·e^{-ikz}",
      "fontSize": 11,
      "fontFamily": 3,
      "createdAt": "2026-04-04T03:21:33.706Z",
      "updatedAt": "2026-04-04T03:21:33.706Z",
      "version": 1
    },
    {
      "id": "mnjrn7k6pca5yqfnat8",
      "type": "text",
      "x": 55,
      "y": 338,
      "strokeColor": "#2f9e44",
      "text": "= φ(-3, y_top) = e^{-9/(2σ²)}",
      "fontSize": 11,
      "fontFamily": 3,
      "createdAt": "2026-04-04T03:21:33.706Z",
      "updatedAt": "2026-04-04T03:21:33.706Z",
      "version": 1
    },
    {
      "id": "mnjrn7k66ve2einqiwo",
      "type": "text",
      "x": 55,
      "y": 356,
      "strokeColor": "#9c36b5",
      "text": "bⱼ = φ(vⱼ + eⱼ/2)·e^{-ikz}",
      "fontSize": 11,
      "fontFamily": 3,
      "createdAt": "2026-04-04T03:21:33.706Z",
      "updatedAt": "2026-04-04T03:21:33.706Z",
      "version": 1
    },
    {
      "id": "mnjrn7k6s6x7ef9r25s",
      "type": "text",
      "x": 55,
      "y": 374,
      "strokeColor": "#9c36b5",
      "text": "= φ(-3, y_bot) = e^{-9/(2σ²)}",
      "fontSize": 11,
      "fontFamily": 3,
      "createdAt": "2026-04-04T03:21:33.706Z",
      "updatedAt": "2026-04-04T03:21:33.706Z",
      "version": 1
    },
