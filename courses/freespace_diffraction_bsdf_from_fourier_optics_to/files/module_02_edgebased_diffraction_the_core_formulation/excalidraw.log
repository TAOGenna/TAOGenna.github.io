},{"id":"mnjrm7261xay0g509fzj","type":"text","x":665,"y":455,"strokeColor":"#1971c2","text":"Factor i/(2πRξ²) in front","fontSize":13,"createdAt":"2026-04-04T03:20:46.404Z","updatedAt":"2026-04-04T03:20:46.404Z","version":1},{"id":"mnjrm726fsthv1j0ui6","type":"text","x":665,"y":145,"strokeColor":"#e03131","text":"Boundary edges only (red)","fontSize":12,"createdAt":"2026-04-04T03:20:46.404Z","updatedAt":"2026-04-04T03:20:46.404Z","version":1},{"id":"arr_main","type":"arrow","x":530,"y":310,"width":80,"height":0,"strokeColor":"#9c36b5","strokeWidth":3,"endArrowhead":"arrow","createdAt":"2026-04-04T03:20:46.404Z","updatedAt":"2026-04-04T03:20:46.404Z","version":1},{"id":"mnjrm726yl7oo4mi3zf","type":"text","x":535,"y":285,"strokeColor":"#9c36b5","text":"Divergence","fontSize":14,"fontFamily":2,"createdAt":"2026-04-04T03:20:46.404Z","updatedAt":"2026-04-04T03:20:46.404Z","version":1},{"id":"mnjrm726kirtwg8e75r","type":"text","x":533,"y":305,"strokeColor":"#9c36b5","text":"Theorem","fontSize":14,"fontFamily":2,"createdAt":"2026-04-04T03:20:46.404Z","updatedAt":"2026-04-04T03:20:46.404Z","version":1},{"id":"mnjrm7267gke18nkff","type":"text","x":80,"y":500,"strokeColor":"#1e1e1e","text":"Key insight: interior edges of adjacent triangles carry opposite normals → contributions cancel.","fontSize":13,"createdAt":"2026-04-04T03:20:46.404Z","updatedAt":"2026-04-04T03:20:46.404Z","version":1},{"id":"mnjrm726bawhddo47gn","type":"text","x":80,"y":520,"strokeColor":"#1e1e1e","text":"Only boundary edges δA⊥ survive. This reduces O(area) work to O(perimeter), and each edge has a closed form!","fontSize":13,"createdAt":"2026-04-04T03:20:46.404Z","updatedAt":"2026-04-04T03:20:46.404Z","version":1}],"count":41}
