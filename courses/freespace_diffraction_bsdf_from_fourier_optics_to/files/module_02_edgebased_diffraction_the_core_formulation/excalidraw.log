2026-04-03 22:22:15.745 [debug] Syncing to canvas: batch_create {"url":"http://localhost:18420/api/elements/batch","data":[{"id":"mnjro401mp6xfj6x0c","type":"text","x":250,"y":10,"strokeColor":"#1e1e1e","text":"Auxiliary Functions α₁ and α₂: Structure, Symmetry, Limits","fontSize":22,"fontFamily":2,"createdAt":"2026-04-04T03:22:15.745Z","updatedAt":"2026-04-04T03:22:15.745Z","version":1},{"id":"mnjro401ge7qgzcudzm","type":"rectangle","x":30,"y":50,"width":480,"height":420,"backgroundColor":"#fff5f5","strokeColor":"#e03131","strokeWidth":2,"roughness":0,"createdAt":"2026-04-04T03:22:15.745Z","updatedAt":"2026-04-04T03:22:15.745Z","version":1},{"id":"mnjro401fxtdhp9vvss","type":"text","x":45,"y":62,"strokeColor":"#e03131","text":"α₁(ζ) — odd in both ζ_x and ζ_y","fontSize":16,"fontFamily":2,"createdAt":"2026-04-04T03:22:15.745Z","updatedAt":"2026-04-04T03:22:15.745Z","version":1},{"id":"mnjro4018v17l417wg5","type":"text","x":45,"y":88,"strokeColor":"#e03131","text":"α₁(ζ) = ζ_y / (2π ζ² ζ_x) · (cos(ζ_x/2) − sin(ζ_x/2)/(ζ_x/2))","fontSize":13,"fontFamily":3,"createdAt":"2026-04-04T03:22:15.745Z","updatedAt":"2026-04-04T03:22:15.745Z","version":1},{"id":"mnjro401i42ox17yjyk","type":"rectangle","x":60,"y":120,"width":180,"height":50,"backgroundColor":"#ffc9c9","strokeColor":"#e03131","strokeWidth":1,"createdAt":"2026-04-04T03:22:15.745Z","updatedAt":"2026-04-04T03:22:15.745Z","version":1},{"id":"mnjro401cst7cy28of","type":"text","x":70,"y":132,"strokeColor":"#1e1e1e","text":"ζ_x > 0, ζ_y > 0","fontSize":12,"createdAt":"2026-04-04T03:22:15.745Z","updatedAt":"2026-04-04T03:22:15.745Z","version":1},{"id":"mnjro401x5sp8tcruj","type":"text","x":70,"y":150,"strokeColor":"#e03131","text":"α₁ < 0  (negative lobe)","fontSize":12,"createdAt":"2026-04-04T03:22:15.745Z","updatedAt":"2026-04-04T03:22:15.745Z","version":1},{"id":"mnjro401jpaj8nxhq5n","type":"rectangle","x":260,"y":120,"width":180,"height":50,"backgroundColor":"#b2f2bb","strokeColor":"#2f9e44","strokeWidth":1,"createdA