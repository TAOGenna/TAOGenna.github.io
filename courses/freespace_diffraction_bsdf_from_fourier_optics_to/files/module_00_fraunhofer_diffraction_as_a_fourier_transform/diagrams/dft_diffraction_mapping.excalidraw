      "type": "text",
      "x": 30,
      "y": 175,
      "strokeColor": "#1971c2",
      "text": "rect(q/w): outside slit=0, inside slit=1; N=7 samples, spacing Δq",
      "fontSize": 12,
      "fontFamily": 2,
      "createdAt": "2026-04-04T02:41:34.522Z",
      "updatedAt": "2026-04-04T02:41:34.522Z",
