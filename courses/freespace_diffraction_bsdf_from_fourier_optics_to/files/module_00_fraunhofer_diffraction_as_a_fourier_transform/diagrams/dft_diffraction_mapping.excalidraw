      "type": "text",
      "x": 30,
      "y": 285,
      "strokeColor": "#2f9e44",
      "text": "Step 2: DFT gives Ψ[m] at N frequencies",
      "fontSize": 15,
      "fontFamily": 2,
      "createdAt": "2026-04-04T02:41:34.522Z",
      "updatedAt": "2026-04-04T02:41:34.522Z",
