    {
      "id": "mnjq8hw9a6yg2chvux6",
      "type": "text",
      "x": 40,
      "y": 315,
      "strokeColor": "#e03131",
      "text": "Ray optics (dashed): sharp box\nWave optics (solid): broad sinc²\nShadow fraction: ~35%\n\nξ₀ = λ/w = 0.5 rad (28°!)",
      "fontSize": 11,
      "fontFamily": 2,
      "createdAt": "2026-04-04T02:42:07.646Z",
      "updatedAt": "2026-04-04T02:42:07.646Z",
      "version": 1
    },
    {
      "id": "mnjq8hw9o23fgsonwlk",
      "type": "text",
      "x": 240,
      "y": 315,
      "strokeColor": "#f08c00",
      "text": "Ray optics: sharp box\nWave optics: visible fringes\nShadow fraction: ~8%\n\nξ₀ = λ/w = 0.1 rad (5.7°)",
      "fontSize": 11,
      "fontFamily": 2,
      "createdAt": "2026-04-04T02:42:07.646Z",
      "updatedAt": "2026-04-04T02:42:07.646Z",
      "version": 1
    },
    {
      "id": "mnjq8hw9irl6lu3wmhi",
      "type": "text",
      "x": 440,
      "y": 315,
      "strokeColor": "#2f9e44",
      "text": "Ray optics: sharp box\nWave optics: weak fringes\nShadow fraction: ~1.6%\n\nξ₀ = λ/w = 0.02 rad (1.1°)",
      "fontSize": 11,
      "fontFamily": 2,
      "createdAt": "2026-04-04T02:42:07.646Z",
      "updatedAt": "2026-04-04T02:42:07.646Z",
      "version": 1
    },
    {
      "id": "mnjq8hw926gxbtsuach",
      "type": "text",
      "x": 640,
      "y": 315,
      "strokeColor": "#1971c2",
      "text": "Ray optics ≈ Wave optics\nTiny fringes at edges\nShadow fraction: ~0.4%\n\nξ₀ = λ/w = 0.005 rad (0.3°)",
      "fontSize": 11,
      "fontFamily": 2,
      "createdAt": "2026-04-04T02:42:07.646Z",
      "updatedAt": "2026-04-04T02:42:07.646Z",
      "version": 1
