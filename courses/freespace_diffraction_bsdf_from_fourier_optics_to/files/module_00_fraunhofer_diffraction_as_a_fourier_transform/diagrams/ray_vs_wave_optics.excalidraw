    {
      "id": "mnjq8hw9r7515zqeyy",
      "type": "text",
      "x": 50,
      "y": 420,
      "strokeColor": "#1e1e1e",
      "text": "Key insight: As w/λ → ∞, wave optics → ray optics. But for w/λ < 50,\ndiffraction bends significant energy into the geometric shadow.",
      "fontSize": 14,
      "fontFamily": 2,
      "createdAt": "2026-04-04T02:42:07.647Z",
      "updatedAt": "2026-04-04T02:42:07.647Z",
      "version": 1
    },
    {
      "id": "mnjq8hw9bgerbip8f9b",
      "type": "text",
      "x": 50,
      "y": 455,
      "strokeColor": "#9c36b5",
      "text": "WiFi doorway: w/λ ≈ 8     Cellular + buildings: w/λ ≈ 23     Visible + 10μm slit: w/λ ≈ 20",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-04T02:42:07.647Z",
      "updatedAt": "2026-04-04T02:42:07.647Z",
