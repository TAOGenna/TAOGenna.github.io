      "x": 250,
      "y": 15,
      "strokeColor": "#1e1e1e",
      "text": "Ray Optics vs Wave Optics: Four Aperture Ratios w/λ",
      "fontSize": 20,
      "fontFamily": 2,
      "createdAt": "2026-04-04T02:42:07.646Z",
      "updatedAt": "2026-04-04T02:42:07.646Z",
      "version": 1
    },
    {
      "id": "mnjq8hw9yojadgujob",
      "type": "text",
      "x": 60,
      "y": 50,
      "strokeColor": "#e03131",
      "text": "w/λ = 2\n(diffraction\ndominates)",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-04T02:42:07.646Z",
      "updatedAt": "2026-04-04T02:42:07.646Z",
      "version": 1
    },
    {
      "id": "mnjq8hw9es2o1f23l3",
      "type": "text",
      "x": 260,
      "y": 50,
      "strokeColor": "#f08c00",
      "text": "w/λ = 10\n(strong\nfringes)",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-04T02:42:07.646Z",
      "updatedAt": "2026-04-04T02:42:07.646Z",
      "version": 1
    },
    {
