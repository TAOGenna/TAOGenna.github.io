t":"2026-04-04T02:42:07.641Z","updatedAt":"2026-04-04T02:42:07.641Z","version":1},{"id":"mnjq8hw9yxblf3a4ano","type":"rectangle","x":630,"y":110,"width":190,"height":200,"backgroundColor":"#f8f8f8","strokeColor":"#aaaaaa","roughness":0,"createdAt":"2026-04-04T02:42:07.641Z","updatedAt":"2026-04-04T02:42:07.641Z","version":1},{"id":"mnjq8hw9zoz24hc6zto","type":"line","x":125,"y":300,"width":0,"height":-90,"strokeColor":"#1e1e1e","strokeWidth":2,"strokeStyle":"dashed","createdAt":"2026-04-04T02:42:07.641Z","updatedAt":"2026-04-04T02:42:07.641Z","version":1},{"id":"mnjq8hw9ddclo9a8fir","type":"line","x":325,"y":300,"width":0,"height":-90,"strokeColor":"#1e1e1e","strokeWidth":2,"strokeStyle":"dashed","createdAt":"2026-04-04T02:42:07.641Z","updatedAt":"2026-04-04T02:42:07.641Z","version":1},{"id":"mnjq8hw9oqooy8s9o3","type":"line","x":525,"y":300,"width":0,"height":-90,"strokeColor":"#1e1e1e","strokeWidth":2,"strokeStyle":"dashed","createdAt":"2026-04-04T02:42:07.641Z","updatedAt":"2026-04-04T02:42:07.641Z","version":1},{"id":"mnjq8hw9q17olxezkp","type":"line","x":725,"y":300,"width":0,"height":-90,"strokeColor":"#1e1e1e","strokeWidth":2,"strokeStyle":"dashed","createdAt":"2026-04-04T02:42:07.641Z","updatedAt":"2026-04-04T02:42:07.641Z","version":1},{"id":"mnjq8hw9a6yg2chvux6","type":"text","x":40,"y":315,"strokeColor":"#e03131","text":"Ray optics (dashed): sharp box\nWave optics (solid): broad sinc²\nShadow fraction: ~35%\n\nξ₀ = λ/w = 0.5 rad (28°!)","fontSize":11,"fontFamily":2,"createdAt":"2026-04-04T02:42:07.641Z","updatedAt":"2026-04-04T02:42:07.641Z","version":1},{"id":"mnjq8hw9o23fgsonwlk","type":"text","x":240,"y":315,"strokeColor":"#f08c00","text":"Ray optics: sharp box\nWave optics: visible fringes\nShadow fraction: ~8%\n\nξ₀ = λ/w = 0.1 rad (5.7°)","fontSize":11,"fontFamily":2,"createdAt":"2026-04-04T02:42:07.641Z","updatedAt":"2026-04-04T02:42:07.641Z","version":1},{"id":"mnjq8hw9irl6lu3wmhi","type":"text","x":440,"y":315,"strokeColor":"#2f9e44","text":"Ray optics: sharp box\nWave optics: weak fringes\nShadow fraction: ~1.6%\n\nξ₀ = λ/w = 0.02 rad (1.1°)","fontSize":11,"fontFamily":2,"createdAt":"2026-04-04T02:42:07.641Z","updatedAt":"2026-04-04T02:42:07.641Z","version":1},{"id":"mnjq8hw926gxbtsuach","type":"text","x":640,"y":315,"strokeColor":"#1971c2","text":"Ray optics ≈ Wave optics\nTiny fringes at edges\nShadow fraction: ~0.4%\n\nξ₀ = λ/w = 0.005 rad (0.3°)","fontSize":11,"fontFamily":2,"createdAt":"2026-04-04T02:42:07.641Z","updatedAt":"2026-04-04T02:42:07.641Z","version":1},{"id":"mnjq8hw9up3v8a1u0cs","type":"line","x":30,"y":200,"width":190,"height":0,"strokeColor":"#e03131","strokeWidth":2,"strokeStyle":"dashed","createdAt":"2026-04-04T02:42:07.641Z","updatedAt":"2026-04-04T02:42:07.641Z","version":1},{"id":"mnjq8hw9pf9mjqdmae","type":"line","x":30,"y":260,"width":50,"height":0,"strokeColor":"#e03131","strokeWidth":2,"strokeStyle":"dashed","createdAt":"2026-04-04T02:42:07.641Z","updatedAt":"2026-04-04T02:42:07.641Z","version":1},{"id":"mnjq8hw9i05fen4zen","type":"line","x":170,"y":260,"width":50,"height":0,"strokeColor":"#e03131","strokeWidth":2,"strokeStyle":"dashed","createdAt":"2026-04-04T02:42:07.641Z","updatedAt":"2026-04-04T02:42:07.641Z","version":1},{"id":"mnjq8hw9d8m2ynvbo5a","type":"line","x":230,"y":195,"width":190,"height":0,"strokeColor":"#f08c00","strokeWidth":2,"strokeStyle":"dashed","createdAt":"2026-04-04T02:42:07.641Z","updatedAt":"2026-04-04T02:42:07.641Z","version":1},{"id":"mnjq8hw9uu7e811m56","type":"line","x":230,"y":260,"width":60,"height":0,"strokeColor":"#f08c00","strokeWidth":2,"strokeStyle":"dashed","createdAt":"2026-04-04T02:42:07.641Z","updatedAt":"2026-04-04T02:42:07.641Z","version":1},{"id":"mnjq8hw9wugqxeuz1cl","type":"line","x":360,"y":260,"width":60,"height":0,"strokeColor":"#f08c00","strokeWidth":2,"strokeStyle":"dashed","createdAt":"2026-04-04T02:42:07.641Z","updatedAt":"2026-04-04T02:42:07.641Z","version":1},{"id":"mnjq8hw9yedpj4jd0zg","type":"line","x":430,"y":193,"width"