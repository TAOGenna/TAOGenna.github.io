      "type": "text",
      "x": 460,
      "y": 119,
      "strokeColor": "#333333",
      "text": "Step 1: Random init + learnable b, e per channel\n(e₀=-8.0, b₀=2.0 for all channels)",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-02T04:56:31.611Z",
