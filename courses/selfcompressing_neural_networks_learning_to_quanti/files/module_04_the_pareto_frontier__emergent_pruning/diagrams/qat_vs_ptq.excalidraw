      "type": "text",
      "x": 460,
      "y": 197,
      "strokeColor": "#333333",
      "text": "Step 2: Train with joint loss:\nL = L_task + λ·Q\n(STE enables gradients through rounding)",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-02T04:56:31.611Z",
