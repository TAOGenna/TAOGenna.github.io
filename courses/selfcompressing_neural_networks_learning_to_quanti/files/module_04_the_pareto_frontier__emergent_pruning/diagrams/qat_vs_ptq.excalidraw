    {
      "id": "mnh05mr5fvp217pxnt5",
      "type": "text",
      "x": 200,
      "y": 15,
      "strokeColor": "#1e1e1e",
      "text": "QAT (Self-Compression) vs. Post-Training Quantization (PTQ)",
      "fontSize": 19,
      "fontFamily": 2,
      "createdAt": "2026-04-02T04:56:31.610Z",
      "updatedAt": "2026-04-02T04:56:31.610Z",
      "version": 1
    },
    {
      "id": "mnh05mr55qo6hpgzhwh",
      "type": "text",
      "x": 230,
      "y": 43,
      "strokeColor": "#555555",
      "text": "Why the model that learns its own compression beats the model that gets compressed afterward",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-02T04:56:31.610Z",
      "updatedAt": "2026-04-02T04:56:31.610Z",
      "version": 1
