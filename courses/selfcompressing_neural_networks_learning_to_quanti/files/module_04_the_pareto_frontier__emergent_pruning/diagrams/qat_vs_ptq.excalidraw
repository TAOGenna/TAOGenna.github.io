    {
      "id": "mnh05mr5dohlepwrzii",
      "type": "text",
      "x": 70,
      "y": 342,
      "strokeColor": "#c05e00",
      "text": "Problem: weights optimized for\ncontinuous float arithmetic.\nAt 2-bit: 4 levels per weight.\nAccuracy: 85-92% (10-13pp gap!)",
      "fontSize": 12,
      "fontFamily": 2,
      "createdAt": "2026-04-02T04:56:31.611Z",
      "updatedAt": "2026-04-02T04:56:31.611Z",
      "version": 1
    },
