      "version": 1
    },
    {
      "id": "mnh05mr5udxdeser1m",
      "type": "text",
      "x": 460,
      "y": 282,
      "strokeColor": "#333333",
      "text": "Step 3: Network ADAPTS to quantization:\nweights cluster near grid points",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-02T04:56:31.611Z",
      "updatedAt": "2026-04-02T04:56:31.611Z",
      "version": 1
    },
    {
      "id": "mnh05mr57fi8siqbo8m",
      "type": "rectangle",
      "x": 450,
      "y": 335,
      "width": 340,
      "height": 80,
      "backgroundColor": "#d0bfff",
      "strokeColor": "#9c36b5",
      "roughness": 0,
      "createdAt": "2026-04-02T04:56:31.611Z",
      "updatedAt": "2026-04-02T04:56:31.611Z",
      "version": 1
    },
    {
      "id": "mnh05mr5wk6i0nw6mh8",
      "type": "text",
      "x": 460,
      "y": 342,
      "strokeColor": "#6a3f8a",
      "text": "Result: 3 advantages over PTQ:\n1) Weights adapted to quantization error\n2) Network learns non-uniform allocation\n3) Low-value channels emerge as pruned\nAccuracy: ~98.2% at same model size!",
      "fontSize": 12,
      "fontFamily": 2,
      "createdAt": "2026-04-02T04:56:31.611Z",
      "updatedAt": "2026-04-02T04:56:31.611Z",
      "version": 1
    },
    {
      "id": "mnh05mr5w4ge9lw8kxq",
      "type": "rectangle",
      "x": 180,
      "y": 460,
      "width": 500,
      "height": 60,
      "backgroundColor": "#a5d8ff",
      "strokeColor": "#1971c2",
      "roughness": 0,
      "createdAt": "2026-04-02T04:56:31.611Z",
      "updatedAt": "2026-04-02T04:56:31.611Z",
      "version": 1
    },
    {
      "id": "mnh05mr5ym6ysdusds",
      "type": "text",
      "x": 200,
      "y": 470,
      "strokeColor": "#1971c2",
      "text": "Gap at 2-bit avg: ~10-13 percentage points in accuracy.\nQAT learns WHICH channels need bits. PTQ allocates uniformly.",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-02T04:56:31.612Z",
      "updatedAt": "2026-04-02T04:56:31.612Z",
      "version": 1
    }
