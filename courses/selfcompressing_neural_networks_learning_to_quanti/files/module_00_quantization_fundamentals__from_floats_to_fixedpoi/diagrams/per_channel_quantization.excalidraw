      "type": "text",
      "x": 470,
      "y": 70,
      "strokeColor": "#9c36b5",
      "text": "Learnable parameters\n(both updated via SGD):",
      "fontSize": 14,
      "createdAt": "2026-04-02T01:35:49.352Z",
      "updatedAt": "2026-04-02T01:35:49.352Z",
      "version": 1
    },
    {
      "id": "params_e",
      "type": "text",
      "x": 470,
      "y": 107,
      "strokeColor": "#1971c2",
      "text": "e: shape (32, 1, 1, 1)\ninit = -8.0 per channel\ncontrols step size 2^e",
      "fontSize": 13,
      "createdAt": "2026-04-02T01:35:49.352Z",
      "updatedAt": "2026-04-02T01:35:49.352Z",
      "version": 1
    },
    {
      "id": "params_b",
      "type": "text",
      "x": 470,
      "y": 163,
      "strokeColor": "#2f9e44",
      "text": "b: shape (32, 1, 1, 1)\ninit = 2.0 per channel\ncontrols # levels 2^relu(b)",
      "fontSize": 13,
      "createdAt": "2026-04-02T01:35:49.352Z",
      "updatedAt": "2026-04-02T01:35:49.352Z",
      "version": 1
    },
    {
      "id": "storage_box",
