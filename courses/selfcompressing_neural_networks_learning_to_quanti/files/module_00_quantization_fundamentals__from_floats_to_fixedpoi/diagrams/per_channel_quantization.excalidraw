    },
    {
      "id": "storage_title",
      "type": "text",
      "x": 470,
      "y": 250,
      "strokeColor": "#0c8599",
      "text": "Storage savings (per channel):",
      "fontSize": 14,
      "createdAt": "2026-04-02T01:35:49.352Z",
      "updatedAt": "2026-04-02T01:35:49.352Z",
      "version": 1
    },
    {
      "id": "storage_detail",
      "type": "text",
      "x": 470,
      "y": 278,
      "strokeColor": "#0c8599",
      "text": "float32: 25 weights × 4B = 100B\nb=4 bits: 25×4/8 = 12.5B\nb=2 bits: 25×2/8 = 6.25B\nb=0 bits: 0B (pruned!)",
      "fontSize": 12,
      "createdAt": "2026-04-02T01:35:49.352Z",
      "updatedAt": "2026-04-02T01:35:49.352Z",
      "version": 1
    },
    {
      "id": "insight_box",
      "type": "rectangle",
      "x": 20,
      "y": 415,
      "width": 670,
      "height": 55,
      "backgroundColor": "#ffec99",
      "strokeColor": "#f08c00",
      "roughness": 0,
      "createdAt": "2026-04-02T01:35:49.352Z",
      "updatedAt": "2026-04-02T01:35:49.352Z",
      "version": 1
    },
    {
      "id": "insight_text",
      "type": "text",
      "x": 30,
      "y": 425,
      "strokeColor": "#f08c00",
      "text": "KEY INSIGHT: Different channels get different precisions. Unimportant channels\nhave b driven toward 0 by the compression loss, emergently pruning them.",
      "fontSize": 14,
      "createdAt": "2026-04-02T01:35:49.352Z",
      "updatedAt": "2026-04-02T01:35:49.352Z",
      "version": 1
    }
