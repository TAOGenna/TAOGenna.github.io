n_spine","type":"rectangle","x":450,"y":100,"width":3,"height":170,"backgroundColor":"#1e1e1e","strokeColor":"#1e1e1e","roughness":0,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"hist_gdn_baseline","type":"rectangle","x":450,"y":268,"width":340,"height":3,"backgroundColor":"#1e1e1e","strokeColor":"#1e1e1e","roughness":0,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"gbar1","type":"rectangle","x":453,"y":223,"width":20,"height":47,"backgroundColor":"#2f9e44","strokeColor":"#2f9e44","roughness":0,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"gbar2","type":"rectangle","x":478,"y":195,"width":20,"height":75,"backgroundColor":"#2f9e44","strokeColor":"#2f9e44","roughness":0,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"gbar3","type":"rectangle","x":503,"y":160,"width":20,"height":110,"backgroundColor":"#2f9e44","strokeColor":"#2f9e44","roughness":0,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"gbar4","type":"rectangle","x":528,"y":130,"width":20,"height":140,"backgroundColor":"#2f9e44","strokeColor":"#2f9e44","roughness":0,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"gbar5","type":"rectangle","x":553,"y":115,"width":20,"height":155,"backgroundColor":"#2f9e44","strokeColor":"#2f9e44","roughness":0,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"gbar6","type":"rectangle","x":578,"y":130,"width":20,"height":140,"backgroundColor":"#2f9e44","strokeColor":"#2f9e44","roughness":0,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"gbar7","type":"rectangle","x":603,"y":160,"width":20,"height":110,"backgroundColor":"#2f9e44","strokeColor":"#2f9e44","roughness":0,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"gbar8","type":"rectangle","x":628,"y":195,"width":20,"height":75,"backgroundColor":"#2f9e44","strokeColor":"#2f9e44","roughness":0,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"gbar9","type":"rectangle","x":653,"y":223,"width":20,"height":47,"backgroundColor":"#2f9e44","strokeColor":"#2f9e44","roughness":0,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"gbar10","type":"rectangle","x":678,"y":248,"width":20,"height":22,"backgroundColor":"#2f9e44","strokeColor":"#2f9e44","roughness":0,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"gbar11","type":"rectangle","x":703,"y":258,"width":20,"height":12,"backgroundColor":"#2f9e44","strokeColor":"#2f9e44","roughness":0,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"gbar12","type":"rectangle","x":728,"y":263,"width":20,"height":7,"backgroundColor":"#2f9e44","strokeColor":"#2f9e44","roughness":0,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"gdn_xlabel","type":"text","x":570,"y":278,"strokeColor":"#1e1e1e","text":"response value  →","fontSize":11,"fontFamily":2,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"gaussian_annotation","type":"text","x":558,"y":100,"strokeColor":"#2f9e44","text":"bell curve!\n(kurtosis ≈ 0)","fontSize":12,"fontFamily":2,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"kurtosis_after","type":"text","x":450,"y":200,"strokeColor":"#2f9e44","text":"kurtosis ≈ 0.1\n(much closer\nto Gaussian)","fontSize":12,"fontFamily":2,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"why_box","type":"rectangle","x":30,"y":320,"width":780,"height":140,"backgroundColor":"#f8f9fa","strokeColor":"#1e1e1e","roughness":0,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"why_title","type":"text","x":40,"y":330,"strokeColor":"#1e1e1e","text":"WHY does Gaussianizing matter for compression?","fontSize":16,"fontFamily":2,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"why1_box_label","type":"text","x":50,"y":355,"strokeColor":"#1971c2","text":"Step 1: Entropy model","fontSize":13,"fontFamily":2,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"why1_content","type":"text","x":50,"y":374,"strokeColor":"#1e1e1e","text":"We model each latent channel independently with\np̃ᵢ ≈ Gaussian. This works well ONLY if each\nchannel's distribution is actually Gaussian-shaped.","fontSize":12,"fontFamily":2,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"why2_box_label","type":"text","x":295,"y":355,"strokeColor":"#f08c00","text":"Step 2: Rate cost","fontSize":13,"fontFamily":2,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"why2_content","type":"text","x":295,"y":374,"strokeColor":"#1e1e1e","text":"Rate = -log p̃(ŷ). If our model is a poor fit,\nwe overestimate entropy → waste bits. A Gaussian\nfit to a heavy-tailed dist wastes ~2× the bits.","fontSize":12,"fontFamily":2,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"why3_box_label","type":"text","x":540,"y":355,"strokeColor":"#2f9e44","text":"Step 3: The payoff","fontSize":13,"fontFamily":2,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"why3_content","type":"text","x":540,"y":374,"strokeColor":"#1e1e1e","text":"GDN-Gaussianized latents allow the entropy model\nto assign tight (low-entropy) codes. Same quality\nimage, fewer bits. That's the compression gain.","fontSize":12,"fontFamily":2,"createdAt":"2026-04-12T12:48:33.842Z","updatedAt":"2026-04-12T12:48:33.842Z","version":1},{"id":"bio_box","type":"rectangle","x":30,"y":476,"width":780,"height":70,"backgroundColor":"#e7f5ff","strokeColor":"#1971c2","roughness":0,"createdAt":"2026-04-12T12:48:33.843Z","updatedAt":"2026-04-12T12:48:33.843Z","version":1},{"id":"bio_title","type":"text","x":40,"y":486,"strokeColor":"#1971c2","text":"Biological origin:","fontSize":14,"fontFamily":2,"createdAt":"2026-04-12T12:48:33.843Z","updatedAt":"2026-04-12T12:48:33.843Z","version":1},{"id":"bio_content","type":"text","x":40,"y":506,"strokeColor":"#1e1e1e","text":"GDN models neurons in visual cortex: each V1 neuron's firing rate is divided by pooled activity of its neighbors.\nThis 'contrast normalization' removes redundancies across orientations and spatial frequencies — the same redundancies\nthat make natural image patches non-Gaussian.","fontSize":12,"fontFamily":2,"createdAt":"2026-04-12T12:48:33.843Z","updatedAt":"2026-04-12T12:48:33.843Z","version":1}]}
