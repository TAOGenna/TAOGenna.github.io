    {
      "id": "mnh06hghakklmi91swe",
      "type": "rectangle",
      "x": 290,
      "y": 305,
      "width": 260,
      "height": 80,
      "backgroundColor": "#ffec99",
      "strokeColor": "#f08c00",
      "roughness": 0,
