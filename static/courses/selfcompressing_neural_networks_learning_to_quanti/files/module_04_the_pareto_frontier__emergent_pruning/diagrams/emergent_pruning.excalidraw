      "version": 1
    },
    {
      "id": "mnh06hghnf2pi7hbvj",
      "type": "text",
      "x": 300,
      "y": 313,
      "strokeColor": "#c05e00",
      "text": "Why b < 0 means pruned:\nrelu(b) = 0 → clamp range = [-0.5, -0.5]\nround(-0.5) = 0 (banker's rounding)\ndequantized weight = 2^e * 0 = 0",
      "fontSize": 12,
      "fontFamily": 3,
      "createdAt": "2026-04-02T04:57:11.414Z",
      "updatedAt": "2026-04-02T04:57:11.414Z",
      "version": 1
    },
    {
      "id": "mnh06hgh9xao052giq",
      "type": "rectangle",
      "x": 290,
      "y": 400,
      "width": 260,
      "height": 85,
      "backgroundColor": "#d0bfff",
      "strokeColor": "#9c36b5",
      "roughness": 0,
      "createdAt": "2026-04-02T04:57:11.414Z",
      "updatedAt": "2026-04-02T04:57:11.414Z",
      "version": 1
    },
    {
      "id": "mnh06hghqfncx9fk8e9",
      "type": "text",
      "x": 300,
      "y": 410,
      "strokeColor": "#6a3f8a",
      "text": "Structured vs unstructured pruning:\nZero-bit channels → entire output removed.\nNot sparse weights — sparse channels.\nCan physically shrink the architecture!",
      "fontSize": 12,
      "fontFamily": 2,
      "createdAt": "2026-04-02T04:57:11.414Z",
      "updatedAt": "2026-04-02T04:57:11.414Z",
      "version": 1
    },
