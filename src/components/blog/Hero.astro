---
import type { CollectionEntry } from 'astro:content'
import { Image } from 'astro:assets'
import FormattedDate from '../FormattedDate.astro'

interface Props {
	content: CollectionEntry<'post'>
	hideAuthorDate?: boolean
}

const {
	content: { data, render },
	hideAuthorDate = false
} = Astro.props

const { remarkPluginFrontmatter } = await render()

const dateTimeOptions: Intl.DateTimeFormatOptions = {
	month: 'long'
}
---

{
	data.coverImage && (
		<div class='aspect-h-9 aspect-w-16 mb-6'>
			<Image
				alt={data.coverImage.alt}
				class='rounded-2xl object-cover'
				fetchpriority='high'
				loading='eager'
				src={data.coverImage.src}
			/>
		</div>
	)
}
{data.draft ? <span class='text-red-500'>(Draft)</span> : null}

{
	hideAuthorDate ? (
		<h1 class='mt-2 font-cormorant text-4xl font-semibold leading-tight sm:mb-1 md:text-5xl'>
			{data.title}
		</h1>
	) : (
		<header class='mt-2 text-center'>
			<h1 class='text-balance font-lora text-4xl font-normal leading-tight text-foreground sm:text-5xl'>
				{data.title}
			</h1>
			{data.description && (
				<p class='mx-auto mt-6 max-w-2xl text-pretty text-base leading-relaxed text-muted-foreground'>
					{data.description}
				</p>
			)}
			<div class='mt-6 flex flex-col items-center gap-1 text-sm text-muted-foreground'>
				<span class='text-foreground/80'>Kenyi Takagui-Perez</span>
				<span>
					<FormattedDate date={data.publishDate} dateTimeOptions={dateTimeOptions} /> ·{' '}
					{remarkPluginFrontmatter.minutesRead}
				</span>
			</div>
		</header>
	)
}
