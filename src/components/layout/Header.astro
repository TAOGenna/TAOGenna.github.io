---
import ModeToggle from '../ModeToggle.astro'

interface Props {
	showModeToggle?: boolean
}

const { showModeToggle = false } = Astro.props
---

<header class='mb-12 w-full pb-3 text-sm'>
	<nav
		class='relative mx-auto grid w-full grid-cols-[1fr_auto_1fr] items-center'
		aria-label='global'
	>
		<!-- Left section -->
		<div class='z-10 flex items-center justify-start pb-8'>
			<a
				href='/'
				class='flex-none font-garamond text-[1.25rem] font-medium transition-colors hover:text-gold'
				aria-label='Nav Menu Item'
				>Home
			</a>
		</div>

		<!-- Center section - equal 1fr columns on each side keep this truly centered -->
		<div class='z-0 flex justify-center pb-8'>
			{showModeToggle && <ModeToggle />}
		</div>

		<!-- Right section -->
		<div class='z-10 flex flex-row items-center justify-end gap-x-6 pb-8 sm:gap-x-8'>
		</div>
	</nav>
</header>
