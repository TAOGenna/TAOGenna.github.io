---
import PageLayout from '../layouts/BaseLayout.astro'
import Section from '../components/Section.astro'
import ProjectCard from '../components/ProjectCard.astro'
import PostPreview from '@/components/blog/PostPreview.astro'
import GeometricDivider from '@/components/GeometricDivider.astro'
import FlippableProfile from '@/components/FlippableProfile.astro'
import Collage from '@/components/Collage.astro'

import { getAllPosts, sortMDByDate } from '@/utils'
import { projects, HOMEPAGE_COUNT } from '@/data/projects'
import RotatingBadge from '@/components/RotatingBadge.astro'

const MAX_POSTS = 10
const allPosts = await getAllPosts()
const sortedPosts = sortMDByDate(allPosts)
const allPostsByDate = [
	...sortedPosts.filter((p) => p.data.pinned),
	...sortedPosts.filter((p) => !p.data.pinned)
].slice(0, MAX_POSTS)

// Peer-reviewed work first, then preprints. Self is bolded in the byline.
const publications = [
	{
		title:
			'Effect of interatomic repulsion on Majorana zero modes in a coupled quantum-dot–superconducting-nanowire hybrid system',
		authors: ['R. Kenyi Takagui Perez', 'A. A. Aligia'],
		venue: 'Phys. Rev. B 109, 075416',
		year: 2024,
		links: [
			{ label: 'DOI', href: 'https://doi.org/10.1103/PhysRevB.109.075416' },
			{ label: 'arXiv', href: 'https://arxiv.org/abs/2309.10888' },
			{ label: 'PDF', href: 'https://arxiv.org/pdf/2309.10888' }
		]
	},
	{
		title:
			'A note on an inversion algorithm for vertical ionograms for the prediction of plasma frequency profiles',
		authors: ['R. Kenyi Takagui Perez'],
		venue: 'arXiv preprint',
		year: 2024,
		links: [
			{ label: 'arXiv', href: 'https://arxiv.org/abs/2411.09215' },
			{ label: 'PDF', href: 'https://arxiv.org/pdf/2411.09215' }
		]
	}
]
---

<PageLayout meta={{ title: 'Home' }} showModeToggle={true}>
	<div class='flex w-full flex-col gap-y-10'>
		<section class='flex flex-col items-center gap-y-4'>
			<FlippableProfile size='lg' />

			<h1
				class='font-cormorant text-5xl font-semibold tracking-wide text-foreground'
				data-mode='professional'
			>
				Kenyi Takagui-Perez
			</h1>

			<h1
				class='font-cormorant text-5xl font-semibold tracking-wide text-foreground'
				data-mode='personal'
			>
				Kenyi
			</h1>

			<div class='social-icons flex flex-row items-center gap-x-5' data-mode='professional'>
				<a href='https://github.com/TAOGenna' aria-label='GitHub'>
					<svg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'><path d='M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12'></path></svg>
				</a>
				<a href='https://www.linkedin.com/in/kenyitakagui/' aria-label='LinkedIn'>
					<svg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'><path d='M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z'></path></svg>
				</a>
				<a href='https://twitter.com/taogenna' aria-label='Twitter'>
					<svg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'><path d='M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z'></path></svg>
				</a>
				<a href='https://scholar.google.com/citations?user=mP_MQh0AAAAJ&hl=en' aria-label='Google Scholar'>
					<svg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'><path d='M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z'></path></svg>
				</a>
			</div>
		</section>

		<Section title='About' data-mode='professional'>
			<div class='flex flex-col gap-y-5 font-garamond text-xl leading-loose'>
				<p>
					Engineer and physicist. Currently working in applied AI engineering at Yavendio.
				</p>
				<p>
					In past lives I was an ML engineer at <a
						class='illuminated-link font-medium text-foreground'
						href='https://play.google.com/store/apps/details?id=com.bcp.innovacxion.yapeapp&hl=es_PE'
						>Yape</a
					> and <a
						class='illuminated-link font-medium text-foreground'
						href='https://spatiali.se/'>Spatialise</a
					>, a geophysicist at <a
						class='illuminated-link font-medium text-foreground'
						href='https://inras.pucp.edu.pe/en/home'>PUCP-INRAS</a
					>, and a grad student in condensed matter physics at the <a
						class='illuminated-link font-medium text-foreground'
						href='https://www.ib.edu.ar/home-english-version/'
						>Balseiro Institute</a
					>.
				</p>
			</div>
		</Section>

		<Section title='About' data-mode='personal'>
			<div class='flex flex-col gap-y-5 font-garamond text-xl leading-loose'>
				<p>
					I'm originally from the highlands of Peru and spent some good years in Argentine Patagonia.
				</p>
				<p>
					In my spare time I enjoy cycling; playing guitar, cello, and piano; and exploring other
					forms of art. Lately I've grown curious about the investment world too.
				</p>
			</div>
		</Section>

			<div data-mode='personal' class='flex flex-col gap-y-6'>
				<GeometricDivider variant='simple' />
				<h2 class='font-cormorant text-2xl font-semibold text-foreground'>Adventures</h2>
				<Collage />
			</div>

			<GeometricDivider variant='simple' data-mode='personal' />

			<Section title='Reading' data-mode='personal'>
				<p class='font-garamond text-xl leading-loose'>
					A running list of books I've read and started — <a
						class='illuminated-link font-medium text-foreground'
						href='/bookshelf'>see the bookshelf</a
					>.
				</p>
			</Section>

		<GeometricDivider variant='simple' data-mode='professional' />

		<Section title="Stuff I've Made" data-mode='professional'>
			<div class='grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3'>
				{
					projects.slice(0, HOMEPAGE_COUNT).map((p) => (
						<ProjectCard
							heading={p.heading}
							href={p.href}
							subheading={p.subheading}
							imagePath={p.imagePath}
							videoPath={p.videoPath}
							altText={p.altText}
							tags={p.tags}
							demo={p.demo}
							class='w-full'
						/>
					))
				}
			</div>
			<div class='mt-10 flex justify-center'>
				<RotatingBadge href='/projects' label='More Work · ' repeat={4} size={140} />
			</div>
		</Section>

		{
			allPostsByDate.length > 0 && (
				<>
					<Section title='Writing' data-mode='professional'>
						<ul class='flex flex-col gap-y-4'>
							{allPostsByDate
								.filter((p) => !p.data.tags.includes('hidden'))
								.map((p) => (
									<PostPreview post={p} />
								))}
						</ul>
					</Section>
				</>
			)
		}

		<Section title='Publications' data-mode='professional'>
			<ul class='flex flex-col gap-y-6'>
				{
					publications.map((pub) => (
						<li class='flex flex-col gap-1'>
							<div class='flex items-baseline justify-between gap-4'>
								<a
									class='illuminated-link font-cormorant text-lg font-semibold'
									href={pub.links[0].href}
									rel='noopener noreferrer'
									target='_blank'
								>
									{pub.title}
								</a>
								<span class='shrink-0 text-sm text-muted-foreground'>{pub.year}</span>
							</div>
							<p class='text-sm leading-relaxed text-muted-foreground'>
								{pub.authors.map((a, i) => (
									<>
										{i > 0 && ', '}
										{a.includes('Takagui') ? (
											<span class='font-medium text-foreground/80'>{a}</span>
										) : (
											a
										)}
									</>
								))}
								{' · '}
								<span class='italic'>{pub.venue}</span>
							</p>
							<div class='mt-0.5 flex flex-wrap gap-x-4 gap-y-1 text-xs'>
								{pub.links.map((l) => (
									<a
										class='text-muted-foreground underline decoration-border underline-offset-2 transition-colors hover:text-gold'
										href={l.href}
										rel='noopener noreferrer'
										target='_blank'
									>
										{l.label} ↗
									</a>
								))}
							</div>
						</li>
					))
				}
			</ul>
		</Section>

		<GeometricDivider variant='simple' data-mode='professional' />

		<Section title='Misc' data-mode='professional'>
			<p class='font-garamond text-xl leading-loose'>
				Coursework, competitions, and other things — <a
					class='illuminated-link font-medium text-foreground'
					href='/misc'>see the misc page</a
				>.
			</p>
		</Section>
	</div>
</PageLayout>

<script>
	function getSiteMode(): 'professional' | 'personal' {
		if (typeof window !== 'undefined') {
			const params = new URLSearchParams(window.location.search)
			const mode = params.get('mode')
			if (mode === 'personal' || mode === 'professional') {
				return mode
			}
		}
		return 'professional'
	}

	function filterContent() {
		const mode = getSiteMode()
		const modedSections = document.querySelectorAll(
			'section[data-mode], div[data-mode], h1[data-mode]'
		)
		modedSections.forEach((section) => {
			const sectionMode = (section as HTMLElement).dataset.mode
			if (sectionMode === mode) {
				;(section as HTMLElement).style.removeProperty('display')
			} else {
				;(section as HTMLElement).style.display = 'none'
			}
		})
	}

	function handlePopState() {
		filterContent()
	}

	document.addEventListener('DOMContentLoaded', () => {
		filterContent()
		window.addEventListener('popstate', handlePopState)
	})

	document.addEventListener('mode-change', () => {
		filterContent()
	})

	document.addEventListener('astro:page-load', () => {
		filterContent()
	})

	if (document.readyState !== 'loading') {
		filterContent()
	}
</script>

<style>
	.social-icons a {
		color: hsl(var(--muted-foreground));
		transition: color 0.2s ease;
	}
	.social-icons a:hover {
		color: hsl(var(--gold));
	}
	.social-icons svg {
		width: 1.25rem;
		height: 1.25rem;
		fill: currentColor;
	}
</style>
