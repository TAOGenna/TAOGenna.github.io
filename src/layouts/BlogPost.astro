---
import type { CollectionEntry } from 'astro:content'

import BlogHero from '@/components/blog/Hero.astro'
import Button from '@/components/Button.astro'

import PageLayout from './BaseLayout.astro'
import Label from '@/components/Label.astro'
import TableOfContents from '@/components/TableOfContents.astro'
import Citation from '@/components/blog/Citation.astro'
import '@fontsource/newsreader'
import 'katex/dist/katex.min.css'

interface Props {
	post: CollectionEntry<'post'>
}

const { post } = Astro.props
const {
	data: { description, ogImage, publishDate, title, updatedDate, tags, citation, citationAuthors },
	slug
} = post

const socialImage = ogImage ?? `/og-image/${slug}.png`
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString()
const { headings } = await post.render()

// Check if this is a spiritual post (tags are normalized to lowercase)
const isSpiritual = tags?.includes('spiritual') ?? false
---

<style is:global>
	/* ---------------------------------------------------------------
	   Reading engine — ported from rajan.sh's per-element type scale.
	   Deliberately flat: headings are Lora, normal-weight, plain
	   foreground, only modestly larger than body. No Tailwind `prose`.
	   --------------------------------------------------------------- */
	.blog-prose {
		color: hsl(var(--foreground) / 0.82);
	}

	.blog-prose :where(h1, h2, h3, h4) {
		color: hsl(var(--foreground));
		font-weight: 400;
		line-height: 1.25;
		text-wrap: balance;
		scroll-margin-top: 6rem;
	}
	.blog-prose h1 {
		font-size: 1.7rem;
		margin: 3rem 0 1.25rem;
	}
	.blog-prose h2 {
		font-size: 1.5rem;
		margin: 3rem 0 1.25rem;
	}
	.blog-prose h3 {
		font-size: 1.2rem;
		font-weight: 500;
		margin: 2.25rem 0 0.75rem;
	}
	.blog-prose h4 {
		font-size: 1.05rem;
		font-weight: 600;
		margin: 1.75rem 0 0.5rem;
	}
	.blog-prose > :first-child {
		margin-top: 0;
	}

	.blog-prose p {
		margin: 0 0 1.4rem;
		text-wrap: pretty;
	}
	.blog-prose ul,
	.blog-prose ol {
		margin: 1.5rem 0;
		padding-left: 1.6rem;
	}
	.blog-prose ul {
		list-style: disc;
	}
	.blog-prose ol {
		list-style: decimal;
	}
	.blog-prose li {
		margin-bottom: 0.4rem;
		line-height: 1.75;
		text-wrap: pretty;
	}
	.blog-prose li::marker {
		color: hsl(var(--muted-foreground) / 0.6);
	}
	.blog-prose li > ul,
	.blog-prose li > ol {
		margin: 0.4rem 0;
	}
	.blog-prose blockquote {
		margin: 2rem 0;
		padding-left: 1.5rem;
		border-left: 2px solid hsl(var(--border));
		color: hsl(var(--foreground) / 0.7);
	}
	.blog-prose a {
		text-decoration: underline;
		text-underline-offset: 2px;
		text-decoration-thickness: 1px;
	}
	.blog-prose strong {
		font-weight: 600;
		color: hsl(var(--foreground));
	}
	.blog-prose :not(pre) > code {
		background: hsl(var(--muted));
		padding: 0.12em 0.36em;
		border-radius: 4px;
		font-size: 0.88em;
	}
	.blog-prose hr {
		margin: 3rem 0;
		border: 0;
		border-top: 1px solid hsl(var(--border));
	}
	.blog-prose table {
		width: 100%;
		margin: 2rem 0;
		font-size: 0.95rem;
		border-collapse: collapse;
	}
	.blog-prose th,
	.blog-prose td {
		padding: 0.5rem 0.75rem;
		border-bottom: 1px solid hsl(var(--border));
		text-align: left;
	}
	.blog-prose th {
		font-weight: 600;
	}

	/* Spiritual posts keep Newsreader headings + their airier size. */
	.blog-prose.font-newsreader :where(h1, h2, h3, h4) {
		font-family: 'Newsreader Variable', serif;
	}

	/* Display math: scroll instead of overflowing the reading column */
	article .katex-display {
		overflow-x: auto;
		overflow-y: hidden;
		padding-block: 0.5rem;
		margin-block: 1.25rem;
	}
	article .katex-display > .katex {
		white-space: nowrap;
	}
	/* Inline math shouldn't inflate line-height */
	article .katex {
		font-size: 1.05em;
	}

	.blog-prose.font-lora {
		font-size: 1.05rem;
		line-height: 1.85;
	}
	.blog-prose.font-newsreader {
		font-size: 1.2rem;
		line-height: 1.8;
	}

	/* --- Sidenotes (Tufte-style margin notes) --- */
	article .sidenote-container {
		position: relative;
	}
	article .sidenote-marker {
		font-size: 0.72em;
		line-height: 0;
		vertical-align: super;
	}
	article .sidenote-ref {
		color: hsl(var(--muted-foreground));
		text-decoration: none;
		padding: 0 0.12em;
	}
	article .sidenote-ref:hover {
		color: hsl(var(--foreground));
	}
	article .sidenote-number {
		color: hsl(var(--foreground));
		font-weight: 600;
		margin-right: 0.3em;
	}
	/* Narrow screens: show the note inline as an indented aside. */
	article .sidenote {
		display: block;
		margin: 0.75rem 0 1.4rem;
		padding-left: 1rem;
		border-left: 2px solid hsl(var(--border));
		font-size: 0.92rem;
		line-height: 1.55;
		color: hsl(var(--muted-foreground));
	}
	article .sidenote .katex {
		font-size: 1em;
	}
	/* Wide screens: float the note into the right margin. */
	@media (min-width: 1280px) {
		article .sidenote {
			float: right;
			clear: right;
			width: 13rem;
			margin: 0.2rem -14.5rem 1rem 0;
			padding-left: 0;
			border-left: none;
			font-size: 0.78rem;
			line-height: 1.5;
			text-align: left;
		}
	}

	/* Centered figures with subdued italic captions */
	article img {
		display: block;
		margin-inline: auto;
		border-radius: 0.5rem;
	}
	article img + em,
	article p > em:only-child {
		display: block;
		text-align: center;
		font-size: 0.9rem;
		color: hsl(var(--muted-foreground));
		margin-top: 0.5rem;
	}
</style>

<PageLayout meta={{ articleDate, description, ogImage: socialImage, title }}>
	<div class='mx-auto w-full max-w-[44rem]'>
		{!isSpiritual && <TableOfContents headings={headings} />}

		<article class='break-words' data-pagefind-body data-spiritual={isSpiritual.toString()}>
			<div id='blog-hero'><BlogHero content={post} hideAuthorDate={isSpiritual} /></div>
			<div
				class:list={['blog-prose mt-12', isSpiritual ? 'font-newsreader' : 'font-lora']}
			>
				<slot />
			</div>
			{citation && <Citation authors={citationAuthors} publishDate={publishDate} slug={slug} title={title} />}
		</article>
		{
			/* 
		<div class='mt-12 w-full border-t border-border pt-4'>
			<p>
				I'm working on more technical writing pieces on AI, startups & games. If you'd like to
				sponsor or want help with your writing, <a
					class='underline'
					href='https://beaded-building-c19.notion.site/Writing-Proposals-12bcc6e515818065bb0dc441c2309bf4'
				>
					you can learn more here.
				</a>
			</p>
		</div>*/
		}
		<button
			aria-label='Back to Top'
			class='z-90 fixed bottom-8 end-4 flex h-8 w-8 translate-y-28 items-center justify-center rounded-full border-2 border-transparent bg-primary-foreground text-3xl opacity-0 transition-all duration-300 hover:border-border/75 data-[show=true]:translate-y-0 data-[show=true]:opacity-100 sm:end-8 sm:h-12 sm:w-12'
			data-show='false'
			id='to-top-btn'
			><svg
				aria-hidden='true'
				class='h-4 w-4'
				fill='none'
				focusable='false'
				stroke='currentColor'
				stroke-width='2'
				viewBox='0 0 24 24'
				xmlns='http://www.w3.org/2000/svg'
			>
				<path d='M4.5 15.75l7.5-7.5 7.5 7.5' stroke-linecap='round' stroke-linejoin='round'></path>
			</svg>
		</button>
	</div>
</PageLayout>

<script>
	// Force light mode for spiritual posts
	const article = document.querySelector('article[data-spiritual]') as HTMLElement
	const isSpiritual = article?.dataset.spiritual === 'true'

	if (isSpiritual) {
		// Immediately set theme to light
		document.documentElement.classList.remove('dark')
		localStorage.setItem('theme', 'light')

		// Block any theme-change events
		document.addEventListener('theme-change', (event) => {
			event.preventDefault()
			event.stopImmediatePropagation()
			// Force it back to light if someone tries to change it
			document.documentElement.classList.remove('dark')
			localStorage.setItem('theme', 'light')
		}, true) // Use capture phase to intercept before other listeners
	}
</script>

<script>
	const scrollBtn = document.getElementById('to-top-btn') as HTMLButtonElement
	const targetHeader = document.getElementById('blog-hero') as HTMLDivElement

	function callback(entries: IntersectionObserverEntry[]) {
		entries.forEach((entry) => {
			// only show the scroll to top button when the heading is out of view
			scrollBtn.dataset.show = (!entry.isIntersecting).toString()
		})
	}

	scrollBtn.addEventListener('click', () => {
		document.documentElement.scrollTo({ behavior: 'smooth', top: 0 })
	})

	const observer = new IntersectionObserver(callback)
	observer.observe(targetHeader)
</script>
