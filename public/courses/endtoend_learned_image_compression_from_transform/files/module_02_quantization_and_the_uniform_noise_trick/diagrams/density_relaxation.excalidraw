      "version": 1
    },
    {
      "id": "convolution_text",
      "type": "text",
      "x": 760,
      "y": 430,
      "strokeColor": "#9c36b5",
      "text": "Why? Convolution theorem:\np_ỹ = p_y ⊛ U(−0.5, 0.5)\nAt integers: integral over\n[n−0.5, n+0.5] = P_q(n) ✓",
      "fontSize": 12,
      "fontFamily": 2,
      "createdAt": "2026-04-12T12:39:05.989Z",
      "updatedAt": "2026-04-12T12:39:05.989Z",
      "version": 1
    }
