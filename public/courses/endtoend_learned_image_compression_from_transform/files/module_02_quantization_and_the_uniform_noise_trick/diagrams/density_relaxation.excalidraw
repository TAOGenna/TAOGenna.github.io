    {
      "id": "title",
      "type": "text",
      "x": 180,
      "y": 20,
      "strokeColor": "#1971c2",
      "text": "The Density Relaxation Property: p_ỹ(n) = P_q(n) for all integers n",
      "fontSize": 22,
      "fontFamily": 2,
      "createdAt": "2026-04-12T12:39:05.987Z",
      "updatedAt": "2026-04-12T12:39:05.987Z",
      "version": 1
    },
    {
      "id": "subtitle",
      "type": "text",
      "x": 280,
      "y": 50,
      "strokeColor": "#1e1e1e",
      "text": "Adding unit-width uniform noise ỹ = y + Δy makes the density equal the PMF at every integer",
      "fontSize": 14,
      "fontFamily": 2,
      "createdAt": "2026-04-12T12:39:05.988Z",
      "updatedAt": "2026-04-12T12:39:05.988Z",
      "version": 1
