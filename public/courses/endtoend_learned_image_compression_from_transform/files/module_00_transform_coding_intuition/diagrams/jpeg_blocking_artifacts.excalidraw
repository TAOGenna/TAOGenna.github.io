    },
    {
      "id": "mnvqotxkvdqjsqrldsa",
      "type": "text",
      "x": 750,
      "y": 145,
      "strokeColor": "#1971c2",
      "text": "Block A pixels\nnear boundary:\n~118, 119, 120",
      "fontSize": 11,
      "fontFamily": 2,
      "createdAt": "2026-04-12T12:28:03.854Z",
      "updatedAt": "2026-04-12T12:28:03.854Z",
      "version": 1
    },
    {
      "id": "mnvqotxku82vbz6s90o",
      "type": "rectangle",
      "x": 905,
