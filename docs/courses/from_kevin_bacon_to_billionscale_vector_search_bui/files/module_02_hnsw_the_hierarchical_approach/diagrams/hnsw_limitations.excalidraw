    },
    {
      "id": "mnhw787dfqquw11lhtp",
      "type": "text",
      "x": 380,
      "y": 73,
      "strokeColor": "#f08c00",
      "text": "LIMITATION 2: No True Deletions",
      "fontSize": 16,
      "fontFamily": 2,
      "createdAt": "2026-04-02T19:53:33.773Z",
      "updatedAt": "2026-04-02T19:53:33.773Z",
      "version": 1
    },
    {
      "id": "mnhw787dxeqc3zb6p",
      "type": "text",
      "x": 380,
      "y": 102,
      "strokeColor": "#1e1e1e",
      "text": "hnswlib uses 'soft delete' — marks node",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-02T19:53:33.773Z",
      "updatedAt": "2026-04-02T19:53:33.773Z",
      "version": 1
    },
    {
      "id": "mnhw787d5w3xkvtd3ck",
      "type": "text",
      "x": 380,
      "y": 122,
      "strokeColor": "#1e1e1e",
      "text": "as deleted, filters at query time.",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-02T19:53:33.773Z",
      "updatedAt": "2026-04-02T19:53:33.773Z",
      "version": 1
    },
    {
      "id": "mnhw787dai3zluh1pvi",
      "type": "text",
      "x": 380,
      "y": 150,
      "strokeColor": "#f08c00",
      "text": "At 10% deletion rate:",
      "fontSize": 14,
      "fontFamily": 2,
      "createdAt": "2026-04-02T19:53:33.773Z",
      "updatedAt": "2026-04-02T19:53:33.773Z",
      "version": 1
    },
    {
      "id": "mnhw787dsb673319tpc",
      "type": "text",
      "x": 380,
      "y": 172,
      "strokeColor": "#1e1e1e",
      "text": "50 hops per search × 10% = 5 wasted hops",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-02T19:53:33.773Z",
      "updatedAt": "2026-04-02T19:53:33.773Z",
      "version": 1
    },
    {
      "id": "mnhw787d5dujvt2n2p7",
      "type": "text",
      "x": 380,
      "y": 192,
      "strokeColor": "#e03131",
      "text": "= 10% more latency, 0% useful work",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-02T19:53:33.773Z",
      "updatedAt": "2026-04-02T19:53:33.773Z",
      "version": 1
    },
