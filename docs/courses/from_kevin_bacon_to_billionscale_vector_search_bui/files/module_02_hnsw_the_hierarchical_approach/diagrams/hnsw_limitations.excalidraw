    {
      "id": "mnhw787d2zts1gndj5b",
      "type": "text",
      "x": 35,
      "y": 278,
      "strokeColor": "#ffffff",
      "text": "RAM: $29,600/month    → 350× more expensive",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-02T19:53:33.773Z",
      "updatedAt": "2026-04-02T19:53:33.773Z",
      "version": 1
    },
    {
      "id": "mnhw787dlb89qhqbksl",
      "type": "text",
      "x": 30,
      "y": 318,
      "strokeColor": "#e03131",
      "text": "Memory: 100ns    SSD: 20,000ns (200× slower)",
      "fontSize": 12,
      "fontFamily": 2,
      "createdAt": "2026-04-02T19:53:33.773Z",
      "updatedAt": "2026-04-02T19:53:33.773Z",
      "version": 1
    },
    {
      "id": "mnhw787dpj4t60bnwi",
      "type": "text",
      "x": 30,
      "y": 348,
      "strokeColor": "#1e1e1e",
      "text": "Can't serve from SSD — latency blows up",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-02T19:53:33.773Z",
      "updatedAt": "2026-04-02T19:53:33.773Z",
      "version": 1
    },
    {
      "id": "del_box",
      "type": "rectangle",
      "x": 370,
