    },
    {
      "id": "mnhw787davqtmt3cc3",
      "type": "text",
      "x": 35,
      "y": 415,
      "strokeColor": "#2f9e44",
      "text": "DiskANN + Vamana Solution (Modules 3-5):",
      "fontSize": 16,
      "fontFamily": 2,
      "createdAt": "2026-04-02T19:53:33.773Z",
      "updatedAt": "2026-04-02T19:53:33.773Z",
      "version": 1
    },
    {
      "id": "mnhw787dp5v4jhh8kq",
      "type": "text",
      "x": 35,
      "y": 442,
      "strokeColor": "#1e1e1e",
      "text": "✔ Single flat graph on SSD with tunable long edges → fewer hops → fewer disk reads",
      "fontSize": 14,
      "fontFamily": 2,
      "createdAt": "2026-04-02T19:53:33.773Z",
      "updatedAt": "2026-04-02T19:53:33.773Z",
      "version": 1
    },
    {
      "id": "mnhw787drw3md8c01ed",
      "type": "text",
      "x": 35,
      "y": 465,
      "strokeColor": "#1e1e1e",
      "text": "✔ True deletion via graph contraction + RobustPrune  |  ✔ Per-node RocksDB entries: O(1) mutation cost",
      "fontSize": 14,
      "fontFamily": 2,
      "createdAt": "2026-04-02T19:53:33.773Z",
      "updatedAt": "2026-04-02T19:53:33.773Z",
      "version": 1
    },
    {
      "id": "mnhw787d8kdjthh9yhi",
      "type": "text",
      "x": 35,
      "y": 488,
      "strokeColor": "#2f9e44",
      "text": "Result: 3 TB RAM cluster → 96 GB RAM single machine  =  ~40× cheaper",
      "fontSize": 15,
      "fontFamily": 2,
      "createdAt": "2026-04-02T19:53:33.773Z",
      "updatedAt": "2026-04-02T19:53:33.773Z",
      "version": 1
    }
  ],
