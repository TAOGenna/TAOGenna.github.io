      "type": "text",
      "x": 30,
      "y": 73,
      "strokeColor": "#e03131",
      "text": "LIMITATION 1: Memory-Only",
      "fontSize": 16,
      "fontFamily": 2,
      "createdAt": "2026-04-02T19:53:33.772Z",
      "updatedAt": "2026-04-02T19:53:33.772Z",
      "version": 1
    },
    {
      "id": "mnhw787d0fqaa16mq67",
      "type": "text",
      "x": 30,
      "y": 102,
      "strokeColor": "#1e1e1e",
      "text": "1B vectors × 768 dims × 4 bytes",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-02T19:53:33.772Z",
      "updatedAt": "2026-04-02T19:53:33.772Z",
      "version": 1
    },
    {
      "id": "mnhw787do56ia71pshj",
      "type": "text",
      "x": 30,
      "y": 122,
      "strokeColor": "#e03131",
      "text": "= 3.072 TB RAM for vectors alone",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-02T19:53:33.772Z",
      "updatedAt": "2026-04-02T19:53:33.772Z",
      "version": 1
    },
    {
      "id": "mnhw787db6q21x80i7m",
      "type": "text",
      "x": 30,
      "y": 148,
      "strokeColor": "#1e1e1e",
      "text": "+ graph edges (M=16):",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-02T19:53:33.772Z",
      "updatedAt": "2026-04-02T19:53:33.772Z",
      "version": 1
    },
    {
      "id": "mnhw787d5nba5cb8cb7",
      "type": "text",
      "x": 30,
      "y": 168,
      "strokeColor": "#1e1e1e",
      "text": "1B × 16 × 4 bytes = 64 GB",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-02T19:53:33.772Z",
      "updatedAt": "2026-04-02T19:53:33.772Z",
      "version": 1
    },
    {
      "id": "mnhw787dyaerhksawk",
      "type": "text",
      "x": 30,
      "y": 188,
      "strokeColor": "#e03131",
      "text": "+ 20% overhead = ~3.7 TB total",
      "fontSize": 14,
