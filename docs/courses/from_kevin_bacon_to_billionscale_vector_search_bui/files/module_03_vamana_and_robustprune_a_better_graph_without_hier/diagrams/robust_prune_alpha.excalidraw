    },
    {
      "id": "mnhx0rvu483r0uy6b3w",
      "type": "text",
      "x": 200,
      "y": 465,
      "strokeColor": "#1e1e1e",
      "text": "Pruning condition: REMOVE candidate q if  dist(p, q) >= alpha * dist(c*, q)",
      "fontSize": 14,
      "createdAt": "2026-04-02T20:16:32.300Z",
      "updatedAt": "2026-04-02T20:16:32.300Z",
      "version": 1
    },
    {
      "id": "mnhx0rvu6jomrb7kb7g",
      "type": "text",
      "x": 200,
      "y": 490,
      "strokeColor": "#9c36b5",
      "text": "Higher alpha = more slack = more long edges survive = better far-away navigation (up to a point)",
      "fontSize": 13,
      "createdAt": "2026-04-02T20:16:32.300Z",
      "updatedAt": "2026-04-02T20:16:32.300Z",
      "version": 1
    }
