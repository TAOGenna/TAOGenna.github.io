    {
      "id": "mnhx0rvuf65cxhlzu9h",
      "type": "text",
      "x": 635,
      "y": 375,
      "strokeColor": "#2f9e44",
      "text": "PRUNED: dist(p,q)=2.0 >= 2.0 * dist(c*,q)=1.0  check: 2.0 >= 2.0 ✗\nKEPT:   dist(p,r)=5.0 >= 2.0 * dist(c*,r)=4.5  check: 5.0 >= 9.0 ✓\nBoth c* and r survive",
      "fontSize": 12,
      "createdAt": "2026-04-02T20:16:32.300Z",
      "updatedAt": "2026-04-02T20:16:32.300Z",
      "version": 1
    },
    {
      "id": "mnhx0rvuykj1a3h26k",
      "type": "text",
      "x": 645,
      "y": 430,
      "strokeColor": "#2f9e44",
      "text": "Result: 2 edges — c* (close) + r (long reach!)",
      "fontSize": 13,
      "createdAt": "2026-04-02T20:16:32.300Z",
      "updatedAt": "2026-04-02T20:16:32.300Z",
      "version": 1
    },
    {
      "id": "mnhx0rvug3l9es9ukoc",
      "type": "line",
      "x": 530,
