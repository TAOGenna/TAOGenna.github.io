    {
      "id": "mnhuotrxgqetyz3prvn",
      "type": "text",
      "x": 270,
      "y": 314,
      "strokeColor": "#9c36b5",
      "text": "d=1000: ratio ≈ 1.03  ← nearest ≈ farthest, kNN breaks down",
      "fontSize": 13,
      "createdAt": "2026-04-02T19:11:15.648Z",
      "updatedAt": "2026-04-02T19:11:15.648Z",
      "version": 1
    },
    {
      "id": "mnhuotrxb8e7ft296os",
      "type": "rectangle",
      "x": 190,
      "y": 65,
      "width": 15,
      "height": 280,
      "backgroundColor": "transparent",
      "strokeColor": "#1e1e1e",
      "strokeWidth": 2,
      "roughness": 0,
      "createdAt": "2026-04-02T19:11:15.648Z",
      "updatedAt": "2026-04-02T19:11:15.648Z",
      "version": 1
    },
    {
      "id": "mnhuotrxezg871qwg7d",
      "type": "text",
      "x": 85,
      "y": 355,
      "strokeColor": "#1e1e1e",
      "text": "Why this matters: any algorithm using 'this candidate is too far away to matter' fails.",
      "fontSize": 14,
      "createdAt": "2026-04-02T19:11:15.648Z",
      "updatedAt": "2026-04-02T19:11:15.648Z",
      "version": 1
    },
    {
      "id": "mnhuotrx05edx60e8oss",
      "type": "text",
      "x": 85,
      "y": 380,
      "strokeColor": "#e03131",
      "text": "When ratio ≈ 1.03, ALL candidates are 'nearly the same distance' from any query.",
      "fontSize": 14,
      "createdAt": "2026-04-02T19:11:15.648Z",
      "updatedAt": "2026-04-02T19:11:15.648Z",
      "version": 1
    },
    {
      "id": "mnhuotrx0wcoz5qfrwx",
      "type": "text",
      "x": 85,
      "y": 405,
      "strokeColor": "#f08c00",
      "text": "k-d tree pruning condition: |q_i - split_i| > d_best  →  almost NEVER true at high d.",
      "fontSize": 13,
      "createdAt": "2026-04-02T19:11:15.648Z",
      "updatedAt": "2026-04-02T19:11:15.648Z",
      "version": 1
    },
    {
      "id": "mnhuotrxv9xpzecbkah",
      "type": "text",
      "x": 85,
      "y": 430,
      "strokeColor": "#e03131",
      "text": "Result: k-d tree visits all n nodes → O(n) per query, same as brute force!",
      "fontSize": 13,
      "createdAt": "2026-04-02T19:11:15.648Z",
      "updatedAt": "2026-04-02T19:11:15.648Z",
      "version": 1
    },
