      "type": "text",
      "x": 80,
      "y": 130,
      "strokeColor": "#e03131",
      "text": "Ratio → 1.0 = distances\nare all the same\n(kNN meaningless)",
      "fontSize": 13,
      "createdAt": "2026-04-02T19:11:15.648Z",
      "updatedAt": "2026-04-02T19:11:15.648Z",
      "version": 1
