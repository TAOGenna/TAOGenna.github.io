      "type": "text",
      "x": 250,
      "y": 20,
      "strokeColor": "#1e1e1e",
      "text": "Max/Min Distance Ratio Converges to 1.0 as Dimensions Grow",
      "fontSize": 20,
      "createdAt": "2026-04-02T19:11:15.648Z",
      "updatedAt": "2026-04-02T19:11:15.648Z",
      "version": 1
    },
    {
      "id": "mnhuotrwmb45u4clygj",
      "type": "text",
      "x": 80,
      "y": 60,
      "strokeColor": "#2f9e44",
      "text": "Ratio >> 1 = distances\nare discriminating\n(kNN easy)",
      "fontSize": 13,
      "createdAt": "2026-04-02T19:11:15.648Z",
      "updatedAt": "2026-04-02T19:11:15.648Z",
      "version": 1
    },
