    },
    {
      "id": "mnhvam6ajj4850rh8pj",
      "type": "text",
      "x": 40,
      "y": 380,
      "strokeColor": "#2f9e44",
      "text": "recall@10 = 0.50 | 0.68 | 0.78 | 0.85 | 0.91 | 0.95",
