      "type": "text",
      "x": 40,
      "y": 355,
      "strokeColor": "#1e1e1e",
      "text": "beam_width=  1  |  10  |  25  |  50  | 100  | 200",
      "fontSize": 13,
      "createdAt": "2026-04-02T19:28:12.233Z",
      "updatedAt": "2026-04-02T19:28:12.233Z",
