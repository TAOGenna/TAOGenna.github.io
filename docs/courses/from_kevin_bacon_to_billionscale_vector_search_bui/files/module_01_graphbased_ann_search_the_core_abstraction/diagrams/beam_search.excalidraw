    },
    {
      "id": "mnhvam6ayyjysuvoix",
      "type": "text",
      "x": 40,
      "y": 405,
      "strokeColor": "#1971c2",
      "text": "nodes_vis =  12  |  45  |  95  | 175  | 320  | 580  (out of 5,000 total = 11.6% max!)",
      "fontSize": 13,
      "createdAt": "2026-04-02T19:28:12.233Z",
      "updatedAt": "2026-04-02T19:28:12.233Z",
      "version": 1
    },
    {
      "id": "mnhvam6an92i4wrxioh",
      "type": "text",
      "x": 40,
      "y": 430,
      "strokeColor": "#9c36b5",
      "text": "↑ The key insight: even beam_width=200 visits only 11.6% of nodes. Sublinear by design.",
      "fontSize": 13,
      "createdAt": "2026-04-02T19:28:12.233Z",
      "updatedAt": "2026-04-02T19:28:12.233Z",
      "version": 1
    },
    {
      "id": "mnhvam6ayte7nlyyljo",
      "type": "text",
      "x": 500,
      "y": 330,
      "strokeColor": "#0c8599",
      "text": "Production ANN systems expose beam_width as the\nprimary latency-recall knob (ef_search in HNSW,\nL in DiskANN). Increase for more accuracy,\ndecrease for lower latency.",
      "fontSize": 13,
      "createdAt": "2026-04-02T19:28:12.233Z",
      "updatedAt": "2026-04-02T19:28:12.233Z",
      "version": 1
    }
