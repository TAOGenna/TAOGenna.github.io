      "y": 15,
      "strokeColor": "#1e1e1e",
      "text": "Backedge Deltas vs. Naive Rewrite",
      "fontSize": 22,
      "createdAt": "2026-04-02T21:04:22.134Z",
      "updatedAt": "2026-04-02T21:04:22.134Z",
      "version": 1
    },
    {
      "id": "mnhyqa9dmvqw30nfhg",
      "type": "text",
      "x": 40,
      "y": 60,
      "strokeColor": "#1e1e1e",
      "text": "Inserting node 5001. It has 3 neighbors: nodes 17, 88, 203. Each needs a backedge.",
      "fontSize": 14,
      "createdAt": "2026-04-02T21:04:22.134Z",
      "updatedAt": "2026-04-02T21:04:22.134Z",
      "version": 1
    },
    {
      "id": "mnhyqa9dyfpcpiz31eq",
      "type": "text",
      "x": 40,
      "y": 95,
      "strokeColor": "#e03131",
      "text": "NAIVE: each backedge immediately rewrites the full entry",
      "fontSize": 16,
      "createdAt": "2026-04-02T21:04:22.134Z",
      "updatedAt": "2026-04-02T21:04:22.134Z",
      "version": 1
    },
