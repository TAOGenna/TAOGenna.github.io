"y":248,"strokeColor":"#9c36b5","text":" 3.717  0.748  4.084  4.088  4.086","fontSize":11,"fontFamily":3,"createdAt":"2026-04-02T04:57:11.393Z","updatedAt":"2026-04-02T04:57:11.393Z","version":1},{"id":"mnh06hgh5fa1k2sc3om","type":"text","x":290,"y":265,"strokeColor":"#9c36b5","text":"  ↑ all active, highest bits of any layer!","fontSize":12,"fontFamily":3,"createdAt":"2026-04-02T04:57:11.393Z","updatedAt":"2026-04-02T04:57:11.393Z","version":1},{"id":"mnh06hghakklmi91swe","type":"rectangle","x":290,"y":305,"width":260,"height":80,"backgroundColor":"#ffec99","strokeColor":"#f08c00","roughness":0,"createdAt":"2026-04-02T04:57:11.393Z","updatedAt":"2026-04-02T04:57:11.393Z","version":1},{"id":"mnh06hghnf2pi7hbvj","type":"text","x":300,"y":313,"strokeColor":"#c05e00","text":"Why b < 0 means pruned:\nrelu(b) = 0 → clamp range = [-0.5, -0.5]\nround(-0.5) = 0 (banker's rounding)\ndequantized weight = 2^e * 0 = 0","fontSize":12,"fontFamily":3,"createdAt":"2026-04-02T04:57:11.393Z","updatedAt":"2026-04-02T04:57:11.393Z","version":1},{"id":"mnh06hgh9xao052giq","type":"rectangle","x":290,"y":400,"width":260,"height":85,"backgroundColor":"#d0bfff","strokeColor":"#9c36b5","roughness":0,"createdAt":"2026-04-02T04:57:11.393Z","updatedAt":"2026-04-02T04:57:11.393Z","version":1},{"id":"mnh06hghqfncx9fk8e9","type":"text","x":300,"y":410,"strokeColor":"#6a3f8a","text":"Structured vs unstructured pruning:\nZero-bit channels → entire output removed.\nNot sparse weights — sparse channels.\nCan physically shrink the architecture!","fontSize":12,"fontFamily":2,"createdAt":"2026-04-02T04:57:11.393Z","updatedAt":"2026-04-02T04:57:11.393Z","version":1},{"id":"mnh06hghkow0pn0rjr","type":"rectangle","x":30,"y":495,"width":120,"height":20,"backgroundColor":"#b2f2bb","strokeColor":"#2f9e44","roughness":0,"createdAt":"2026-04-02T04:57:11.393Z","updatedAt":"2026-04-02T04:57:11.393Z","version":1},{"id":"mnh06hghclg8wsw547a","type":"text","x":35,"y":500,"strokeColor":"#2f9e44","text":"Active (relu(b) > 0)","fontSize":12,"fontFamily":2,"createdAt":"2026-04-02T04:57:11.393Z","updatedAt":"2026-04-02T04:57:11.393Z","version":1},{"id":"mnh06hghkrppmhjcp5","type":"rectangle","x":165,"y":495,"width":120,"height":20,"backgroundColor":"#e03131","strokeColor":"#e03131","roughness":0,"createdAt":"2026-04-02T04:57:11.393Z","updatedAt":"2026-04-02T04:57:11.393Z","version":1},{"id":"mnh06hgh4faymk1ncop","type":"text","x":170,"y":500,"strokeColor":"#ffffff","text":"Pruned (relu(b) = 0)","fontSize":12,"fontFamily":2,"createdAt":"2026-04-02T04:57:11.393Z","updatedAt":"2026-04-02T04:57:11.393Z","version":1}]}
