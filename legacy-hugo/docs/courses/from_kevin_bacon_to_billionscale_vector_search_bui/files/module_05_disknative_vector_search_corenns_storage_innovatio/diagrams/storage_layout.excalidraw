    },
    {
      "id": "mnhypdiesoxcs7ky0ej",
      "type": "text",
      "x": 150,
      "y": 430,
      "strokeColor": "#1e1e1e",
      "text": "00 00 00 2A\n4 bytes (big-endian)",
      "fontSize": 10,
      "createdAt": "2026-04-02T21:03:39.691Z",
      "updatedAt": "2026-04-02T21:03:39.691Z",
      "version": 1
    },
    {
      "id": "mnhypdiez4kb5ng6tsc",
      "type": "text",
      "x": 280,
      "y": 430,
      "strokeColor": "#1e1e1e",
      "text": "← node 42 in binary. Not '4','2' (2 bytes) but 0x0000002A (4 bytes).",
      "fontSize": 12,
      "createdAt": "2026-04-02T21:03:39.691Z",
      "updatedAt": "2026-04-02T21:03:39.691Z",
      "version": 1
    },
    {
      "id": "mnhypdiezeincyqemxa",
      "type": "text",
      "x": 280,
      "y": 450,
      "strokeColor": "#1e1e1e",
      "text": "Saves 2+ bytes per key vs string format. At 1B entries that's 2+ GB less index size.",
      "fontSize": 12,
      "createdAt": "2026-04-02T21:03:39.691Z",
      "updatedAt": "2026-04-02T21:03:39.691Z",
      "version": 1
    }
