      "version": 1
    },
    {
      "id": "mnhypdie1qxowgk61n4",
      "type": "text",
      "x": 60,
      "y": 340,
      "strokeColor": "#1971c2",
      "text": "Key insight: We needed the neighbor list anyway (to know where to go next).\nThe vector comes along for free within the same 4K page.\nThis enables implicit re-ranking without any extra I/O.",
      "fontSize": 13,
      "createdAt": "2026-04-02T21:03:39.691Z",
      "updatedAt": "2026-04-02T21:03:39.691Z",
      "version": 1
    },
    {
      "id": "mnhypdietd1ojqltnjn",
      "type": "text",
      "x": 60,
      "y": 400,
      "strokeColor": "#1e1e1e",
      "text": "Binary key format (compact):",
      "fontSize": 13,
      "createdAt": "2026-04-02T21:03:39.691Z",
      "updatedAt": "2026-04-02T21:03:39.691Z",
      "version": 1
    },
