      "createdAt": "2026-04-02T21:03:39.691Z",
      "updatedAt": "2026-04-02T21:03:39.691Z",
      "version": 1
    },
    {
      "id": "mnhypdieyqdt3090yuc",
      "type": "text",
      "x": 700,
      "y": 315,
      "strokeColor": "#2f9e44",
      "text": "Get neighbor list AND full-precision vector in one shot!",
      "fontSize": 12,
      "createdAt": "2026-04-02T21:03:39.691Z",
      "updatedAt": "2026-04-02T21:03:39.691Z",
      "version": 1
    },
    {
      "id": "arr3",
      "type": "arrow",
      "x": 960,
      "y": 225,
      "width": 0,
      "height": 15,
      "strokeColor": "#9c36b5",
