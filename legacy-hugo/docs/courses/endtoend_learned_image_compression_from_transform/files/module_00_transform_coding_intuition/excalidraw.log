:"mnvqo1rqki4m1pmzcip","type":"text","x":1235,"y":118,"strokeColor":"#1e1e1e","text":"x̂ ≈ [0.84, 0.91, 0.70,\n0.42, 0.08, -0.30,\n-0.58, -0.71, -0.60,\n-0.27, 0.17, 0.60]","fontSize":11,"fontFamily":3,"createdAt":"2026-04-12T12:27:27.400Z","updatedAt":"2026-04-12T12:27:27.400Z","version":1},{"id":"mnvqo1rq3tjvm5u2mzb","type":"text","x":1235,"y":195,"strokeColor":"#2f9e44","text":"MSE ≈ 0.0001","fontSize":10,"fontFamily":2,"createdAt":"2026-04-12T12:27:27.400Z","updatedAt":"2026-04-12T12:27:27.400Z","version":1},{"id":"mnvqo1rqr74ovqk8erg","type":"arrow","x":1172.997501171265,"y":146.8249375292816,"width":60,"height":0,"strokeColor":"#1e1e1e","strokeWidth":2,"points":[[0,0],[44.004997657470085,1.1001249414367749]],"start":{"id":"decoder_box"},"end":{"id":"output_box"},"endArrowhead":"arrow","createdAt":"2026-04-12T12:27:27.400Z","updatedAt":"2026-04-12T12:27:27.400Z","version":1},{"id":"mnvqo1rq6ibniap30fc","type":"text","x":30,"y":230,"strokeColor":"#1971c2","text":"KEY INSIGHT: The transform concentrates signal energy.\nMost of the signal lives in coefficient [0] = 4.21 (the DC component + 3Hz sine).\nAll high-freq coefficients ≈ 0 → round to 0 → free!","fontSize":12,"fontFamily":2,"createdAt":"2026-04-12T12:27:27.400Z","updatedAt":"2026-04-12T12:27:27.400Z","version":1},{"id":"mnvqo1rqahqao2s4rgt","type":"rectangle","x":425,"y":280,"width":550,"height":60,"backgroundColor":"#a5d8ff","strokeColor":"#1971c2","strokeWidth":1,"roughness":0,"createdAt":"2026-04-12T12:27:27.400Z","updatedAt":"2026-04-12T12:27:27.400Z","version":1},{"id":"mnvqo1rqr8rec2uw4bo","type":"text","x":440,"y":293,"strokeColor":"#1971c2","text":"RATE: only 2 coefficients need bits → ~4 bits total\nDISTORTION: MSE ≈ 0.0001 (excellent reconstruction)","fontSize":12,"fontFamily":2,"createdAt":"2026-04-12T12:27:27.400Z","updatedAt":"2026-04-12T12:27:27.400Z","version":1},{"id":"mnvqo1rqf8sjytjxuy9","type":"text","x":30,"y":365,"strokeColor":"#1e1e1e","text":"JPEG does this with a fixed DCT basis (left). Ballé et al. LEARN the transforms jointly to minimize R + λD (right).","fontSize":12,"fontFamily":2,"createdAt":"2026-04-12T12:27:27.400Z","updatedAt":"2026-04-12T12:27:27.400Z","version":1},{"id":"mnvqo1rqdft7e1dl1jb","type":"text","x":182,"y":260,"strokeColor":"#e03131","text":"LINEAR (JPEG)\nfixed DCT\nbasis","fontSize":11,"fontFamily":2,"createdAt":"2026-04-12T12:27:27.400Z","updatedAt":"2026-04-12T12:27:27.400Z","version":1},{"id":"mnvqo1rqx7a8yfn0k0j","type":"text","x":1003,"y":260,"strokeColor":"#2f9e44","text":"NONLINEAR (learned)\ng_a warps the space\nfor better quantization","fontSize":11,"fontFamily":2,"createdAt":"2026-04-12T12:27:27.401Z","updatedAt":"2026-04-12T12:27:27.401Z","version":1}],"count":39}
