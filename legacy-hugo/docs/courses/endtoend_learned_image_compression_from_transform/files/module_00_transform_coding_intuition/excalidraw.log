,"fontFamily":2,"createdAt":"2026-04-12T12:27:27.350Z","updatedAt":"2026-04-12T12:27:27.350Z","version":1},{"id":"mnvqo1rqx7a8yfn0k0j","type":"text","x":1003,"y":260,"strokeColor":"#2f9e44","text":"NONLINEAR (learned)\ng_a warps the space\nfor better quantization","fontSize":11,"fontFamily":2,"createdAt":"2026-04-12T12:27:27.350Z","updatedAt":"2026-04-12T12:27:27.350Z","version":1}]}
