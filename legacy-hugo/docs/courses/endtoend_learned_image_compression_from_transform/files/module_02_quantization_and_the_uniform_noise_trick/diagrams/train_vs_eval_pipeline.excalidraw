      "version": 1
    },
    {
      "id": "bridge_body",
      "type": "text",
      "x": 955,
      "y": 242,
      "strokeColor": "#2f9e44",
      "text": "h[ỹ] ≈ H[q]\n(key theorem)\n\nProxy loss ≈\nactual loss\n\nTraining with\nnoise yields\nalmost the same\nweights as if\nwe could train\nwith rounding",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-12T12:40:00.484Z",
      "updatedAt": "2026-04-12T12:40:00.484Z",
      "version": 1
    },
