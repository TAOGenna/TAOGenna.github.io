    {
      "id": "bridge_title",
      "type": "text",
      "x": 960,
      "y": 215,
      "strokeColor": "#2f9e44",
      "text": "Why this works:",
      "fontSize": 16,
      "fontFamily": 2,
      "createdAt": "2026-04-12T12:40:00.484Z",
