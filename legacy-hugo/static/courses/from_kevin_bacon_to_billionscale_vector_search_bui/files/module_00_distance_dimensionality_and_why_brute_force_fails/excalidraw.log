60,"backgroundColor":"#a5d8ff","strokeColor":"#2f9e44","roughness":0,"createdAt":"2026-04-02T19:10:47.397Z","updatedAt":"2026-04-02T19:10:47.397Z","version":1},{"id":"mnhuo7z9ldj4xhglrnn","type":"text","x":450,"y":195,"strokeColor":"#2f9e44","text":"Center\n35%","fontSize":14,"createdAt":"2026-04-02T19:10:47.397Z","updatedAt":"2026-04-02T19:10:47.397Z","version":1},{"id":"mnhuo7z92zypj61ovt","type":"text","x":510,"y":140,"strokeColor":"#e03131","text":"Edge\n65%","fontSize":14,"createdAt":"2026-04-02T19:10:47.397Z","updatedAt":"2026-04-02T19:10:47.397Z","version":1},{"id":"mnhuo7z9h79wls5gsqi","type":"text","x":720,"y":70,"strokeColor":"#9c36b5","text":"100D Ball","fontSize":16,"createdAt":"2026-04-02T19:10:47.397Z","updatedAt":"2026-04-02T19:10:47.397Z","version":1},{"id":"circle_outer_100d","type":"ellipse","x":720,"y":110,"width":200,"height":200,"backgroundColor":"#ffc9c9","strokeColor":"#9c36b5","roughness":0,"createdAt":"2026-04-02T19:10:47.397Z","updatedAt":"2026-04-02T19:10:47.397Z","version":1},{"id":"circle_inner_100d","type":"ellipse","x":740,"y":130,"width":160,"height":160,"backgroundColor":"#ffc9c9","strokeColor":"#9c36b5","roughness":0,"createdAt":"2026-04-02T19:10:47.397Z","updatedAt":"2026-04-02T19:10:47.397Z","version":1},{"id":"mnhuo7z9fv9r2fsykt7","type":"text","x":770,"y":185,"strokeColor":"#9c36b5","text":"Center\n<0.01%","fontSize":12,"createdAt":"2026-04-02T19:10:47.397Z","updatedAt":"2026-04-02T19:10:47.397Z","version":1},{"id":"mnhuo7z9ugbmov2srh","type":"text","x":840,"y":140,"strokeColor":"#e03131","text":"Edge\n~100%","fontSize":14,"createdAt":"2026-04-02T19:10:47.397Z","updatedAt":"2026-04-02T19:10:47.397Z","version":1},{"id":"mnhuo7z9g3dr9pn9gn5","type":"text","x":80,"y":330,"strokeColor":"#1e1e1e","text":"Formula: fraction in outer ε-shell = 1 - (1-ε)^d","fontSize":14,"createdAt":"2026-04-02T19:10:47.397Z","updatedAt":"2026-04-02T19:10:47.397Z","version":1},{"id":"mnhuo7z9yqj2t3vd94","type":"text","x":80,"y":360,"strokeColor":"#e03131","text":"At d=100, ε=0.1:  1 - (0.9)^100 ≈ 99.997%","fontSize":14,"createdAt":"2026-04-02T19:10:47.397Z","updatedAt":"2026-04-02T19:10:47.397Z","version":1},{"id":"mnhuo7z9bvazrmzgtj","type":"text","x":80,"y":395,"strokeColor":"#1e1e1e","text":"Key insight: ALL points are 'near the boundary' in high dimensions.","fontSize":14,"createdAt":"2026-04-02T19:10:47.397Z","updatedAt":"2026-04-02T19:10:47.397Z","version":1},{"id":"mnhuo7z9dar8t6sugcq","type":"text","x":80,"y":420,"strokeColor":"#e03131","text":"So every point is about the same distance from every query — the nearest neighbor has no special proximity!","fontSize":14,"createdAt":"2026-04-02T19:10:47.397Z","updatedAt":"2026-04-02T19:10:47.397Z","version":1},{"id":"mnhuo7z92bahrq91oo2","type":"rectangle","x":70,"y":385,"width":940,"height":65,"backgroundColor":"#ffc9c9","strokeColor":"#e03131","roughness":0,"strokeStyle":"dashed","createdAt":"2026-04-02T19:10:47.397Z","updatedAt":"2026-04-02T19:10:47.397Z","version":1},{"id":"mnhuo7z9ahl2qb6k5do","type":"text","x":80,"y":460,"strokeColor":"#f08c00","text":"This is why k-d trees fail: they prune by assuming the 'other side' is clearly farther away.","fontSize":13,"createdAt":"2026-04-02T19:10:47.397Z","updatedAt":"2026-04-02T19:10:47.397Z","version":1},{"id":"mnhuo7z9vtfeg5ezbp","type":"text","x":80,"y":480,"strokeColor":"#f08c00","text":"In high dimensions, nothing is clearly farther — so they visit every node.","fontSize":13,"createdAt":"2026-04-02T19:10:47.397Z","updatedAt":"2026-04-02T19:10:47.397Z","version":1}]}
