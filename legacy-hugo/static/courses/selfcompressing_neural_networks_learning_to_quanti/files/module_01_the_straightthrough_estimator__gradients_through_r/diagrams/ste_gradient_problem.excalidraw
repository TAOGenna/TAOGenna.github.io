    },
    {
      "id": "mngu0oyqxn9ci0d1v1",
      "type": "text",
      "x": 630,
      "y": 148,
      "strokeColor": "#e03131",
      "text": "d/dx[round(x)] = 0",
      "fontSize": 15,
      "fontFamily": 3,
      "createdAt": "2026-04-02T02:04:43.541Z",
      "updatedAt": "2026-04-02T02:04:43.541Z",
      "version": 1
    },
    {
      "id": "mngu0oyqz5tm8s3zguj",
      "type": "text",
      "x": 630,
      "y": 175,
      "strokeColor": "#1e1e1e",
      "text": "almost everywhere",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-02T02:04:43.541Z",
      "updatedAt": "2026-04-02T02:04:43.541Z",
      "version": 1
    },
    {
      "id": "mngu0oyqt9md9g2jn4",
      "type": "text",
      "x": 630,
      "y": 198,
      "strokeColor": "#e03131",
      "text": "⇒ weight.grad = 0",
      "fontSize": 14,
      "fontFamily": 3,
      "createdAt": "2026-04-02T02:04:43.541Z",
      "updatedAt": "2026-04-02T02:04:43.541Z",
      "version": 1
    },
    {
