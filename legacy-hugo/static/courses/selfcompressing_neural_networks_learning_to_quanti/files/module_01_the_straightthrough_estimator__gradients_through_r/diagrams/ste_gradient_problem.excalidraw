    {
      "id": "mngu0oyqdbd0zkfxzao",
      "type": "text",
      "x": 630,
      "y": 260,
      "strokeColor": "#f08c00",
      "text": "CONSEQUENCE",
      "fontSize": 15,
      "fontFamily": 2,
      "createdAt": "2026-04-02T02:04:43.541Z",
      "updatedAt": "2026-04-02T02:04:43.541Z",
      "version": 1
    },
    {
      "id": "mngu0oyqqvai5n4msad",
      "type": "text",
      "x": 630,
      "y": 285,
      "strokeColor": "#1e1e1e",
      "text": "• Optimizer sees grad=0",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-02T02:04:43.542Z",
      "updatedAt": "2026-04-02T02:04:43.542Z",
      "version": 1
    },
    {
      "id": "mngu0oyq3a5n3tc6ety",
      "type": "text",
      "x": 630,
      "y": 305,
      "strokeColor": "#1e1e1e",
      "text": "• Weights never update",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-02T02:04:43.542Z",
      "updatedAt": "2026-04-02T02:04:43.542Z",
      "version": 1
    },
    {
      "id": "mngu0oyqg6lxsdbfhgf",
      "type": "text",
      "x": 630,
      "y": 325,
      "strokeColor": "#1e1e1e",
      "text": "• Loss stays constant",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-02T02:04:43.542Z",
      "updatedAt": "2026-04-02T02:04:43.542Z",
      "version": 1
    },
    {
      "id": "mngu0oyq0vd5xatnnwd",
      "type": "text",
      "x": 630,
      "y": 345,
      "strokeColor": "#1e1e1e",
      "text": "• Training fails entirely",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-02T02:04:43.542Z",
      "updatedAt": "2026-04-02T02:04:43.542Z",
      "version": 1
    },
    {
      "id": "mngu0oyqcjfaals5yz",
      "type": "text",
      "x": 80,
      "y": 390,
      "strokeColor": "#e03131",
      "text": "Slope = 0 between every step — derivative of a staircase is always zero",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-02T02:04:43.542Z",
      "updatedAt": "2026-04-02T02:04:43.542Z",
      "version": 1
