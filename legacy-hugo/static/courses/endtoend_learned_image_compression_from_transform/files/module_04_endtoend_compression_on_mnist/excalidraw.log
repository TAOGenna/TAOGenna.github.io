olor":"#2f9e44","strokeWidth":2,"points":[[0,0],[-54,0]],"start":{"id":"syn2"},"end":{"id":"syn1"},"endArrowhead":"arrow","createdAt":"2026-04-12T12:55:50.857Z","updatedAt":"2026-04-12T12:55:50.857Z","version":1},{"id":"arr9","type":"arrow","x":212.09789627736745,"y":401.87927953515253,"width":0,"height":0,"strokeColor":"#2f9e44","strokeWidth":2,"points":[[0,0],[-44.19579255473491,6.97828303495811]],"start":{"id":"syn1"},"end":{"id":"output_img"},"endArrowhead":"arrow","createdAt":"2026-04-12T12:55:50.857Z","updatedAt":"2026-04-12T12:55:50.857Z","version":1},{"id":"distortion_note","type":"text","x":60,"y":480,"strokeColor":"#2f9e44","text":"Distortion D = MSE(x, x̂)  ←  gradients flow back through synthesis and analysis","fontSize":13,"fontFamily":2,"createdAt":"2026-04-12T12:55:50.857Z","updatedAt":"2026-04-12T12:55:50.857Z","version":1},{"id":"loss_note","type":"text","x":60,"y":500,"strokeColor":"#e03131","text":"Objective: minimize  L = R + λ·D  (λ controls the rate-distortion tradeoff)","fontSize":14,"fontFamily":2,"createdAt":"2026-04-12T12:55:50.858Z","updatedAt":"2026-04-12T12:55:50.858Z","version":1},{"id":"ga_brace","type":"text","x":390,"y":245,"strokeColor":"#9c36b5","text":"← Analysis transform g_a (encoder) →","fontSize":13,"fontFamily":2,"createdAt":"2026-04-12T12:55:50.858Z","updatedAt":"2026-04-12T12:55:50.858Z","version":1},{"id":"gs_brace","type":"text","x":370,"y":460,"strokeColor":"#2f9e44","text":"← Synthesis transform g_s (decoder) →","fontSize":13,"fontFamily":2,"createdAt":"2026-04-12T12:55:50.858Z","updatedAt":"2026-04-12T12:55:50.858Z","version":1}],"count":44}
