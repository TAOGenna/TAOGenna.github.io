      "type": "text",
      "x": 378,
      "y": 580,
      "strokeColor": "#888",
      "text": "... (128 channels)",
      "fontSize": 12,
      "fontFamily": 2,
      "createdAt": "2026-04-12T12:49:48.852Z",
      "updatedAt": "2026-04-12T12:49:48.852Z",
      "version": 1
    },
    {
      "id": "key_insight",
      "type": "text",
      "x": 30,
      "y": 632,
      "strokeColor": "#e03131",
      "text": "KEY INSIGHT: each channel's output depends on ALL channels' inputs at (m,n).\nThis captures cross-channel dependencies — impossible with pointwise ReLU.",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-12T12:49:48.852Z",
      "updatedAt": "2026-04-12T12:49:48.852Z",
      "version": 1
    },
    {
      "id": "vs_relu_box",
      "type": "rectangle",
      "x": 530,
      "y": 90,
      "width": 260,
      "height": 250,
      "backgroundColor": "#fff3bf",
      "strokeColor": "#f08c00",
      "strokeStyle": "dashed",
      "roughness": 0,
      "createdAt": "2026-04-12T12:49:48.853Z",
      "updatedAt": "2026-04-12T12:49:48.853Z",
      "version": 1
    },
    {
      "id": "vs_relu_title",
      "type": "text",
      "x": 570,
      "y": 100,
      "strokeColor": "#f08c00",
      "text": "vs. ReLU (pointwise)",
      "fontSize": 15,
      "fontFamily": 2,
      "createdAt": "2026-04-12T12:49:48.853Z",
      "updatedAt": "2026-04-12T12:49:48.853Z",
      "version": 1
    },
    {
      "id": "vs_relu_eq",
      "type": "text",
      "x": 545,
      "y": 130,
      "strokeColor": "#1e1e1e",
      "text": "u₁ = max(0, w₁) = 2.3\nu₂ = max(0, w₂) = 0.0\nu₃ = max(0, w₃) = 3.1",
      "fontSize": 14,
      "fontFamily": 3,
      "createdAt": "2026-04-12T12:49:48.853Z",
      "updatedAt": "2026-04-12T12:49:48.853Z",
      "version": 1
    },
    {
      "id": "vs_relu_note1",
      "type": "text",
      "x": 545,
      "y": 210,
      "strokeColor": "#e03131",
      "text": "✗ ignores channel 2 entirely\n   (negative → dead)",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-12T12:49:48.853Z",
      "updatedAt": "2026-04-12T12:49:48.853Z",
      "version": 1
    },
    {
      "id": "vs_relu_note2",
      "type": "text",
      "x": 545,
      "y": 258,
      "strokeColor": "#e03131",
      "text": "✗ u₃=3.1 stays large even if\n   ALL other channels are huge\n   (no gain control!)",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-12T12:49:48.853Z",
      "updatedAt": "2026-04-12T12:49:48.853Z",
      "version": 1
    },
    {
      "id": "vs_relu_note3",
      "type": "text",
      "x": 545,
      "y": 310,
      "strokeColor": "#e03131",
      "text": "✗ output statistics remain\n   heavy-tailed → bad for\n   entropy coding",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-12T12:49:48.853Z",
      "updatedAt": "2026-04-12T12:49:48.853Z",
      "version": 1
    },
    {
      "id": "vs_gdn_box",
      "type": "rectangle",
      "x": 530,
      "y": 360,
      "width": 260,
      "height": 200,
      "backgroundColor": "#d3f9d8",
      "strokeColor": "#2f9e44",
      "strokeStyle": "dashed",
      "roughness": 0,
      "createdAt": "2026-04-12T12:49:48.853Z",
      "updatedAt": "2026-04-12T12:49:48.853Z",
      "version": 1
    },
    {
      "id": "vs_gdn_title",
      "type": "text",
      "x": 590,
      "y": 370,
      "strokeColor": "#2f9e44",
      "text": "GDN (joint)",
      "fontSize": 15,
      "fontFamily": 2,
      "createdAt": "2026-04-12T12:49:48.853Z",
      "updatedAt": "2026-04-12T12:49:48.853Z",
      "version": 1
    },
    {
      "id": "vs_gdn_note1",
      "type": "text",
      "x": 545,
      "y": 398,
      "strokeColor": "#2f9e44",
      "text": "✓ all channels suppress each other\n   (local gain control)",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-12T12:49:48.853Z",
      "updatedAt": "2026-04-12T12:49:48.853Z",
      "version": 1
    },
    {
      "id": "vs_gdn_note2",
      "type": "text",
      "x": 545,
      "y": 440,
      "strokeColor": "#2f9e44",
      "text": "✓ output approx Gaussian even\n   when inputs are heavy-tailed",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-12T12:49:48.853Z",
      "updatedAt": "2026-04-12T12:49:48.853Z",
      "version": 1
    },
    {
      "id": "vs_gdn_note3",
      "type": "text",
      "x": 545,
      "y": 478,
      "strokeColor": "#2f9e44",
      "text": "✓ fewer stages needed for\n   same R-D performance",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-12T12:49:48.853Z",
      "updatedAt": "2026-04-12T12:49:48.853Z",
      "version": 1
    },
    {
      "id": "vs_gdn_note4",
      "type": "text",
      "x": 545,
      "y": 518,
      "strokeColor": "#2f9e44",
      "text": "✓ spatially adaptive\n   (unlike batch norm)",
      "fontSize": 13,
      "fontFamily": 2,
      "createdAt": "2026-04-12T12:49:48.853Z",
      "updatedAt": "2026-04-12T12:49:48.853Z",
      "version": 1
    },
